<section class="numbers reveal">
  <div class="container">
    <div class="numbers-grid">
      <div class="number-card"><strong>41</strong><span>CEC en Chile</span></div>
      <div class="number-card"><strong>8</strong><span>Procedimientos cubiertos</span></div>

        <div class="proc-visual-row">
          <span class="proc-visual-dot ok"></span>
          <span class="proc-visual-label">Resueltos</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:10%"></div></div>
          <span class="proc-visual-val">2</span>
        </div>
      </div>
    </div>

    <div class="proc-panel" data-panel="5">
      <div class="proc-info">
        <h3>Control de Documentos</h3>
        <p>Administra el ciclo de vida de documentos normativos: creacion, revision, aprobacion, distribucion y obsolescencia.</p>
        <div class="proc-features">
          <div class="proc-feat"><span class="check">✓</span> Versionado automatico</div>
          <div class="proc-feat"><span class="check">✓</span> Flujo de aprobacion</div>
          <div class="proc-feat"><span class="check">✓</span> Lista maestra</div>
          <div class="proc-feat"><span class="check">✓</span> Control de copias</div>
        </div>
      </div>
      <div class="proc-visual">
        <div class="proc-visual-row">
          <span class="proc-visual-dot ok"></span>
          <span class="proc-visual-label">Vigentes</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:70%"></div></div>

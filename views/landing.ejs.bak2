        <div class="proc-visual-row">
          <span class="proc-visual-dot warn"></span>
          <span class="proc-visual-label">Detectados</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:10%;background:#F59E0B"></div></div>
          <span class="proc-visual-val">2</span>

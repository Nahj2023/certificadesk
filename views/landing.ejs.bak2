<section class="pricing" id="precios">
  <div class="container">
    <div class="pricing-header reveal">
      <h2>Un plan para cada CEC</h2>
      <p>Sin permanencia. Implementacion guiada incluida. Migra tus datos sin costo.</p>
    </div>
    <div class="pricing-grid reveal">
      <div class="price-card">
        <p class="price-name">Starter</p>
        <p class="price-desc">Para CEC con hasta 3 perfiles y 1 evaluador interno.</p>
        <div class="price-amount"><strong>$49.990</strong> <span>CLP/mes</span></div>
        <ul class="price-features">
          <li>Procedimientos 1 al 8</li>
          <li>Hasta 50 candidatos/mes</li>
          <li>1 usuario administrador</li>
          <li>Soporte por email</li>
          <li>Reportes basicos</li>
        </ul>
        <a href="#contacto" class="btn-price ghost">Empezar</a>
      </div>
      <div class="price-card featured">
        <p class="price-name">Professional</p>
        <p class="price-desc">Para CEC con multiples perfiles y equipo de evaluadores.</p>
        <div class="price-amount"><strong>$99.990</strong> <span>CLP/mes</span></div>
        <ul class="price-features">
          <li>Todo lo de Starter</li>
          <li>Candidatos ilimitados</li>
          <li>Hasta 10 usuarios</li>
          <li>Soporte prioritario</li>
          <li>Reportes ChileValora</li>
          <li>Portafolio digital</li>
        </ul>
        <a href="#contacto" class="btn-price fill">Empezar</a>
      </div>
      <div class="price-card">
        <p class="price-name">Enterprise</p>
        <p class="price-desc">Para OTEC o redes de CEC con operacion nacional.</p>
        <div class="price-amount"><strong>$199.990</strong> <span>CLP/mes</span></div>
        <ul class="price-features">
          <li>Todo lo de Professional</li>
          <li>Usuarios ilimitados</li>
          <li>Multi-sede</li>
          <li>API de integracion</li>
          <li>SLA 99.9% + soporte dedicado</li>
        </ul>
        <a href="#contacto" class="btn-price ghost">Contactar</a>
      </div>
    </div>
  </div>
</section>

<section class="cta-section" id="contacto">
  <div class="container">
    <div class="cta-box reveal">
      <h2>Deja de improvisar con Excel</h2>
      <p>Agenda una demo de 20 minutos y ve como CertificaDesk resuelve tus 8 procedimientos.</p>
      <a href="mailto:contacto@jvh-labs.cl?subject=Demo%20CertificaDesk" class="btn-primary">Agendar demo gratuita &rarr;</a>
      <p class="cta-contact">O escribe a <a href="mailto:contacto@jvh-labs.cl">contacto@jvh-labs.cl</a></p>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <span class="footer-copy">&copy; 2026 CertificaDesk &mdash; JVH Labs</span>
      <div class="footer-links">
        <a href="https://jvh-labs.cl">JVH Labs</a>
        <a href="/login">Acceder</a>
      </div>
    </div>
  </div>
</footer>

<script>
document.querySelectorAll('.proc-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.proc-tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.proc-panel').forEach(p=>p.classList.remove('active'));
    tab.classList.add('active');
    document.querySelector('[data-panel="'+tab.dataset.tab+'"]').classList.add('active');
  });
});
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}})
},{threshold:0.15});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>
</body>
</html>

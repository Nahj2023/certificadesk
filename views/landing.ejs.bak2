          <span class="proc-visual-val">4</span>
        </div>
        <div class="proc-visual-row">
          <span class="proc-visual-dot ok"></span>
          <span class="proc-visual-label">Felicitaciones</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:55%"></div></div>
          <span class="proc-visual-val">12</span>
        </div>
        <div class="proc-visual-row">
          <span class="proc-visual-dot warn"></span>
          <span class="proc-visual-label">Sugerencias</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:35%;background:#F59E0B"></div></div>
          <span class="proc-visual-val">8</span>
        </div>
        <div class="proc-visual-row">
          <span class="proc-visual-dot ok"></span>
          <span class="proc-visual-label">Cerrados</span>
          <div class="proc-visual-bar"><div class="proc-visual-fill" style="width:85%"></div></div>
          <span class="proc-visual-val">21</span>
        </div>
      </div>
    </div>

    <div class="proc-panel" data-panel="4">
      <div class="proc-info">
        <h3>Conflictos de Interes</h3>
        <p>Declaracion, revision y resolucion de conflictos de interes entre evaluadores, candidatos y personal del CEC.</p>
        <div class="proc-features">
          <div class="proc-feat"><span class="check">✓</span> Declaracion jurada digital</div>
          <div class="proc-feat"><span class="check">✓</span> Validacion cruzada automatica</div>
          <div class="proc-feat"><span class="check">✓</span> Acta de resolucion</div>
          <div class="proc-feat"><span class="check">✓</span> Registro historico</div>
        </div>
      </div>
      <div class="proc-visual">
        <div class="proc-visual-row">
          <span class="proc-visual-dot ok"></span>
          <span class="proc-visual-label">Declaraciones</span>

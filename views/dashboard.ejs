<% const title = 'Dashboard' %>
<%- include('partials/header', { title }) %>

<h4 class="mb-4">Dashboard</h4>
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Candidatos</div><div class="stat-value"><%= stats.candidates %></div></div>
          <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-people fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Certificados</div><div class="stat-value"><%= stats.certified %></div></div>
          <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-patch-check fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Eval. Pendientes</div><div class="stat-value"><%= stats.pending %></div></div>
          <div class="stat-icon bg-warning-subtle text-warning"><i class="bi bi-clock fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Reclamos Abiertos</div><div class="stat-value"><%= stats.complaints_open %></div></div>
          <div class="stat-icon bg-danger-subtle text-danger"><i class="bi bi-exclamation-triangle fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Evaluadores</div><div class="stat-value"><%= stats.evaluators %></div></div>
          <div class="stat-icon bg-info-subtle text-info"><i class="bi bi-person-badge fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Docs por Vencer</div><div class="stat-value"><%= stats.docs_expiring %></div></div>
          <div class="stat-icon bg-warning-subtle text-warning"><i class="bi bi-file-earmark-x fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Satisfaccion</div><div class="stat-value"><%= stats.satisfaction_avg ? Number(stats.satisfaction_avg).toFixed(1) : '-' %>/5</div></div>
          <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-emoji-smile fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div><div class="stat-label">Evaluaciones</div><div class="stat-value"><%= stats.evaluations %></div></div>
          <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-clipboard-check fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- D016 Compliance Pipeline -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white"><strong><i class="bi bi-funnel"></i> Pipeline Certificacion D016</strong></div>
  <div class="card-body">
    <div class="row text-center">
      <div class="col">
        <div class="border rounded p-2">
          <div class="text-muted small">Registrados</div>
          <div class="fs-4 fw-bold"><%= stats.registrados %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-info">
          <div class="text-info small">Elegibles</div>
          <div class="fs-4 fw-bold text-info"><%= stats.elegibles %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-warning">
          <div class="text-warning small">Evaluando</div>
          <div class="fs-4 fw-bold text-warning"><%= stats.evaluando %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-primary">
          <div class="text-primary small">Pend. Comite</div>
          <div class="fs-4 fw-bold text-primary"><%= stats.pendiente_comite %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-success">
          <div class="text-success small">Certificados</div>
          <div class="fs-4 fw-bold text-success"><%= stats.certificados %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- D016 Compliance Alerts -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="bi bi-book fs-3 <%= stats.manuales >= 3 ? 'text-success' : 'text-danger' %>"></i>
        <div class="stat-label mt-1">Manuales ChileValora</div>
        <div class="stat-value"><%= stats.manuales %>/3</div>
        <% if (stats.manuales < 3) { %><small class="text-danger">Faltan manuales obligatorios</small><% } else { %><small class="text-success">Completos</small><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="bi bi-clipboard2-check fs-3 <%= stats.eval_reviews_pending === 0 ? 'text-success' : 'text-warning' %>"></i>
        <div class="stat-label mt-1">Eval. Desempeno Pendientes</div>
        <div class="stat-value"><%= stats.eval_reviews_pending %></div>
        <% if (stats.eval_reviews_pending > 0) { %><small class="text-warning">Evaluadores sin evaluar este ano</small><% } else { %><small class="text-success">Al dia</small><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center">
        <i class="bi bi-file-earmark-bar-graph fs-3 text-primary"></i>
        <div class="stat-label mt-1">Reporte ChileValora</div>
        <a href="/reportes/chilevalora" class="btn btn-sm btn-outline-primary mt-1">Generar Reporte Mensual</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white"><strong>Proximas Evaluaciones</strong></div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>Candidato</th><th>Perfil</th><th>Fecha</th></tr></thead>
          <tbody>
            <% if (upcoming.length === 0) { %>
              <tr><td colspan="3" class="text-muted text-center py-3">Sin evaluaciones programadas</td></tr>
            <% } else { upcoming.forEach(e => { %>
              <tr><td><%= e.candidate_name || '-' %></td><td><%= e.profile_name || '-' %></td><td><%= e.scheduled_date || '-' %></td></tr>
            <% })} %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white"><strong>Actividad Reciente</strong></div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead><tr><th>Accion</th><th>Tipo</th><th>Detalle</th></tr></thead>
          <tbody>
            <% if (recent.length === 0) { %>
              <tr><td colspan="3" class="text-muted text-center py-3">Sin actividad reciente</td></tr>
            <% } else { recent.forEach(a => { %>
              <tr><td><%= a.action %></td><td><%= a.entity_type || '' %></td><td><%= a.details || '' %></td></tr>
            <% })} %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<% const title = 'Dashboard' %>
<%- include('partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Dashboard</h4>
    <span class="text-muted" style="font-size:0.85rem">Resumen operacional CEC</span>
  </div>
  <div class="d-flex gap-2">
    <a href="/reportes/chilevalora" class="btn btn-sm btn-outline-primary"><i class="bi bi-file-earmark-bar-graph"></i> Reporte ChileValora</a>
    <a href="/candidatos/nuevo" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Candidato</a>
  </div>
</div>

<!-- Stat cards row 1 -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Candidatos</div>
            <div class="stat-value"><%= stats.candidates %></div>
          </div>
          <div class="stat-icon coral"><i class="bi bi-people fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Certificados</div>
            <div class="stat-value"><%= stats.certified %></div>
          </div>
          <div class="stat-icon green"><i class="bi bi-patch-check fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Eval. Pendientes</div>
            <div class="stat-value"><%= stats.pending %></div>
          </div>
          <div class="stat-icon orange"><i class="bi bi-clock fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Reclamos Abiertos</div>
            <div class="stat-value"><%= stats.complaints_open %></div>
          </div>
          <div class="stat-icon red"><i class="bi bi-exclamation-triangle fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stat cards row 2 -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Evaluadores</div>
            <div class="stat-value"><%= stats.evaluators %></div>
          </div>
          <div class="stat-icon blue"><i class="bi bi-person-badge fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Docs por Vencer</div>
            <div class="stat-value"><%= stats.docs_expiring %></div>
          </div>
          <div class="stat-icon orange"><i class="bi bi-file-earmark-x fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Satisfaccion</div>
            <div class="stat-value"><%= stats.satisfaction_avg ? Number(stats.satisfaction_avg).toFixed(1) : '-' %><small style="font-size:0.9rem;font-weight:500">/5</small></div>
          </div>
          <div class="stat-icon green"><i class="bi bi-emoji-smile fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="stat-label">Evaluaciones</div>
            <div class="stat-value"><%= stats.evaluations %></div>
          </div>
          <div class="stat-icon purple"><i class="bi bi-clipboard-check fs-4"></i></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Pipeline D016 -->
<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <strong><i class="bi bi-funnel"></i> Pipeline Certificacion D016</strong>
    <span class="badge bg-secondary"><%= stats.candidates %> total</span>
  </div>
  <div class="card-body py-4">
    <div class="row align-items-center text-center g-2">
      <div class="col">
        <div class="pipeline-step">
          <div class="step-label text-muted">Registrados</div>
          <div class="step-value"><%= stats.registrados %></div>
        </div>
      </div>
      <div class="col-auto pipeline-arrow"><i class="bi bi-chevron-right"></i></div>
      <div class="col">
        <div class="pipeline-step" style="border-color: var(--blue)">
          <div class="step-label" style="color: var(--blue)">Elegibles</div>
          <div class="step-value" style="color: var(--blue)"><%= stats.elegibles %></div>
        </div>
      </div>
      <div class="col-auto pipeline-arrow"><i class="bi bi-chevron-right"></i></div>
      <div class="col">
        <div class="pipeline-step" style="border-color: var(--orange)">
          <div class="step-label" style="color: var(--orange)">Evaluando</div>
          <div class="step-value" style="color: var(--orange)"><%= stats.evaluando %></div>
        </div>
      </div>
      <div class="col-auto pipeline-arrow"><i class="bi bi-chevron-right"></i></div>
      <div class="col">
        <div class="pipeline-step" style="border-color: var(--coral)">
          <div class="step-label" style="color: var(--coral)">Pend. Comite</div>
          <div class="step-value" style="color: var(--coral)"><%= stats.pendiente_comite %></div>
        </div>
      </div>
      <div class="col-auto pipeline-arrow"><i class="bi bi-chevron-right"></i></div>
      <div class="col">
        <div class="pipeline-step" style="border-color: var(--green)">
          <div class="step-label" style="color: var(--green)">Certificados</div>
          <div class="step-value" style="color: var(--green)"><%= stats.certificados %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Charts row -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-pie-chart"></i> Candidatos por Estado</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px">
        <canvas id="chartPipeline"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-bar-chart"></i> Candidatos por Perfil</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px">
        <canvas id="chartProfiles"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-graph-up"></i> Evaluaciones por Mes</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px">
        <canvas id="chartMonthly"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- D016 Compliance -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body text-center py-4">
        <div class="stat-icon mx-auto mb-3 <%= stats.manuales >= 3 ? 'green' : 'red' %>">
          <i class="bi bi-book fs-4"></i>
        </div>
        <div class="stat-label">Manuales ChileValora</div>
        <div class="stat-value mt-1"><%= stats.manuales %><small style="font-size:1rem;font-weight:500">/3</small></div>
        <% if (stats.manuales < 3) { %><span class="badge bg-danger mt-2">Incompleto</span><% } else { %><span class="badge bg-success mt-2">Completos</span><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body text-center py-4">
        <div class="stat-icon mx-auto mb-3 <%= stats.eval_reviews_pending === 0 ? 'green' : 'orange' %>">
          <i class="bi bi-clipboard2-check fs-4"></i>
        </div>
        <div class="stat-label">Eval. Desempeno Pendientes</div>
        <div class="stat-value mt-1"><%= stats.eval_reviews_pending %></div>
        <% if (stats.eval_reviews_pending > 0) { %><span class="badge bg-warning mt-2">Pendiente</span><% } else { %><span class="badge bg-success mt-2">Al dia</span><% } %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body text-center py-4">
        <div class="stat-icon mx-auto mb-3 blue">
          <i class="bi bi-file-earmark-bar-graph fs-4"></i>
        </div>
        <div class="stat-label">Reporte ChileValora</div>
        <div class="mt-3">
          <a href="/reportes/chilevalora" class="btn btn-sm btn-primary"><i class="bi bi-download"></i> Generar Mensual</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tables -->
<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Proximas Evaluaciones</strong>
        <a href="/evaluaciones" class="btn btn-sm btn-outline-primary">Ver todas</a>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Candidato</th><th>Perfil</th><th>Fecha</th></tr></thead>
          <tbody>
            <% if (upcoming.length === 0) { %>
              <tr><td colspan="3" class="empty-state"><i class="bi bi-calendar-x"></i>Sin evaluaciones programadas</td></tr>
            <% } else { upcoming.forEach(e => { %>
              <tr><td><%= e.candidate_name || '-' %></td><td><%= e.profile_name || '-' %></td><td><%= e.scheduled_date || '-' %></td></tr>
            <% })} %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Actividad Reciente</strong>
        <span class="badge bg-secondary"><%= recent.length %></span>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Accion</th><th>Tipo</th><th>Detalle</th></tr></thead>
          <tbody>
            <% if (recent.length === 0) { %>
              <tr><td colspan="3" class="empty-state"><i class="bi bi-clock-history"></i>Sin actividad reciente</td></tr>
            <% } else { recent.forEach(a => { %>
              <tr><td><%= a.action %></td><td><span class="badge bg-secondary"><%= a.entity_type || '' %></span></td><td class="text-muted"><%= a.details || '' %></td></tr>
            <% })} %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
(function() {
  const coral = '#E85D3A', green = '#2ECC71', blue = '#3498DB', orange = '#F39C12', purple = '#9B59B6',
        red = '#E74C3C', teal = '#00B894', gray = '#636E72';
  const chartFont = { family: "'Inter', sans-serif", size: 11 };
  Chart.defaults.font = chartFont;
  Chart.defaults.plugins.legend.labels.usePointStyle = true;
  Chart.defaults.plugins.legend.labels.padding = 12;

  // Donut: candidatos por estado
  const pipeData = <%- JSON.stringify(charts.pipeline) %>;
  new Chart(document.getElementById('chartPipeline'), {
    type: 'doughnut',
    data: {
      labels: ['Registrados', 'Elegibles', 'Evaluando', 'Pend. Comite', 'Certificados'],
      datasets: [{
        data: pipeData,
        backgroundColor: [gray, blue, orange, coral, green],
        borderWidth: 0, hoverOffset: 6
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      cutout: '60%',
      plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }
    }
  });

  // Bar: candidatos por perfil
  const profData = <%- JSON.stringify(charts.byProfile) %>;
  new Chart(document.getElementById('chartProfiles'), {
    type: 'bar',
    data: {
      labels: profData.map(d => d.label ? (d.label.length > 18 ? d.label.substring(0,18)+'...' : d.label) : 'N/A'),
      datasets: [{
        label: 'Candidatos',
        data: profData.map(d => d.value),
        backgroundColor: coral + 'CC',
        borderRadius: 6, barThickness: 28
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, indexAxis: 'y',
      scales: { x: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 10 } }, grid: { display: false } }, y: { ticks: { font: { size: 10 } }, grid: { display: false } } },
      plugins: { legend: { display: false } }
    }
  });

  // Line: evaluaciones por mes
  const monthData = <%- JSON.stringify(charts.byMonth) %>;
  if (monthData.length > 0) {
    new Chart(document.getElementById('chartMonthly'), {
      type: 'line',
      data: {
        labels: monthData.map(d => d.month),
        datasets: [
          { label: 'Competentes', data: monthData.map(d => d.competentes), borderColor: green, backgroundColor: green+'33', fill: true, tension: 0.35, pointRadius: 4, pointBackgroundColor: green },
          { label: 'No Competentes', data: monthData.map(d => d.no_competentes), borderColor: red, backgroundColor: red+'22', fill: true, tension: 0.35, pointRadius: 4, pointBackgroundColor: red }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } },
        plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }
      }
    });
  } else {
    document.getElementById('chartMonthly').parentElement.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-graph-up" style="font-size:2rem"></i><br>Sin datos aun</div>';
  }
})();
</script>

<%- include('partials/footer') %>

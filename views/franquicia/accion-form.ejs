<% const title = accion && accion.id ? 'Editar Accion' : 'Nueva Accion EyCCL' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1"><%= title %></h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 8 — Registro de accion EyCCL</span>
  </div>
  <a href="/franquicia" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<form method="POST" action="<%= accion && accion.id ? '/franquicia/' + accion.id : '/franquicia' %>">
  <div class="row g-4">
    <div class="col-md-6">
      <div class="card mb-4">
        <div class="card-header"><i class="bi bi-building me-2" style="color:var(--coral)"></i> Datos de la Empresa</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12"><label class="form-label">RUT Empresa *</label><input type="text" name="empresa_rut" class="form-control" value="<%= accion?.empresa_rut || '' %>" required placeholder="76.000.000-0"></div>
            <div class="col-12"><label class="form-label">Razon Social *</label><input type="text" name="empresa_nombre" class="form-control" value="<%= accion?.empresa_nombre || '' %>" required></div>
            <div class="col-12"><label class="form-label">Direccion</label><input type="text" name="empresa_direccion" class="form-control" value="<%= accion?.empresa_direccion || '' %>"></div>
            <div class="col-6"><label class="form-label">Region</label><input type="text" name="empresa_region" class="form-control" value="<%= accion?.empresa_region || '' %>"></div>
            <div class="col-6"><label class="form-label">Comuna</label><input type="text" name="empresa_comuna" class="form-control" value="<%= accion?.empresa_comuna || '' %>"></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><i class="bi bi-clipboard-data me-2" style="color:var(--coral)"></i> Datos de la Accion</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12"><label class="form-label">Tipo de Actividad *</label>
              <select name="tipo" class="form-select" required>
                <option value="contrato" <%= accion?.tipo === 'contrato' ? 'selected' : '' %>>Contrato</option>
                <option value="pre_contrato" <%= accion?.tipo === 'pre_contrato' ? 'selected' : '' %>>Pre Contrato</option>
                <option value="post_contrato" <%= accion?.tipo === 'post_contrato' ? 'selected' : '' %>>Post Contrato</option>
              </select>
            </div>
            <div class="col-12"><label class="form-label">Perfil Ocupacional</label>
              <select name="profile_id" class="form-select"><option value="">Seleccionar...</option>
                <% profiles.forEach(p => { %><option value="<%= p.id %>" <%= accion?.profile_id == p.id ? 'selected' : '' %>><%= p.code %> — <%= p.name %></option><% }) %>
              </select>
            </div>
            <div class="col-6"><label class="form-label">Fecha Inicio</label><input type="date" name="fecha_inicio" class="form-control" value="<%= accion?.fecha_inicio || '' %>"></div>
            <div class="col-6"><label class="form-label">Fecha Termino</label><input type="date" name="fecha_termino" class="form-control" value="<%= accion?.fecha_termino || '' %>"></div>
            <div class="col-12"><label class="form-label">Valor por UCL ($CLP)</label><input type="number" name="valor_ucl" class="form-control" value="<%= accion?.valor_ucl || '' %>" min="0" step="1000"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card mb-4">
        <div class="card-header"><i class="bi bi-person-lines-fill me-2" style="color:var(--coral)"></i> Responsable de Comunicar</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12"><label class="form-label">RUT Responsable</label><input type="text" name="responsable_rut" class="form-control" value="<%= accion?.responsable_rut || '' %>"></div>
            <div class="col-12"><label class="form-label">Nombre</label><input type="text" name="responsable_nombre" class="form-control" value="<%= accion?.responsable_nombre || '' %>"></div>
            <div class="col-6"><label class="form-label">Email</label><input type="email" name="responsable_email" class="form-control" value="<%= accion?.responsable_email || '' %>"></div>
            <div class="col-6"><label class="form-label">Telefono</label><input type="text" name="responsable_telefono" class="form-control" value="<%= accion?.responsable_telefono || '' %>"></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><i class="bi bi-people me-2" style="color:var(--coral)"></i> Comite Bipartito</div>
        <div class="card-body">
          <div class="form-check mb-3"><input type="checkbox" name="tiene_comite_bipartito" value="1" class="form-check-input" id="cb" <%= accion?.tiene_comite_bipartito ? 'checked' : '' %>><label for="cb" class="form-check-label">Empresa cuenta con Comite Bipartito aprobado por SENCE</label></div>
          <div class="mb-3"><label class="form-label">Programa asociado</label><input type="text" name="comite_programa" class="form-control" value="<%= accion?.comite_programa || '' %>" placeholder="Nombre del programa CB"></div>
          <div class="p-2 rounded mb-3" style="background:rgba(232,93,58,0.06);border-left:3px solid var(--coral)">
            <small class="text-muted"><i class="bi bi-info-circle"></i> Solo acciones tipo <strong>Contrato</strong> aplican para beneficio de Comite Bipartito.</small>
          </div>
          <div class="mb-0"><label class="form-label">Observaciones</label><textarea name="observaciones" class="form-control" rows="3"><%= accion?.observaciones || '' %></textarea></div>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-4 d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> <%= accion && accion.id ? 'Guardar Cambios' : 'Crear Accion' %></button>
    <a href="/franquicia" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>
<%- include('../partials/footer') %>
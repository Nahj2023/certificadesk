<% const title = 'Franquicia Tributaria SENCE' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Franquicia Tributaria — EyCCL SENCE</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 8 — Acciones de certificacion con franquicia</span>
  </div>
  <a href="/franquicia/nueva" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nueva Accion</a>
</div>

<div class="card mb-4">
  <div class="card-header"><i class="bi bi-signpost-split me-2" style="color:var(--coral)"></i> Pipeline de Acciones</div>
  <div class="card-body">
    <div class="d-flex justify-content-between text-center gap-2 flex-wrap">
      <div class="pipeline-step flex-fill"><div class="text-muted small">Borrador</div><div class="fs-4 fw-bold"><%= stats.borrador %></div></div>
      <div class="d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="pipeline-step flex-fill" style="border-color:var(--bs-info)"><div class="text-info small">Comunicada</div><div class="fs-4 fw-bold text-info"><%= stats.comunicadas %></div></div>
      <div class="d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="pipeline-step flex-fill" style="border-color:var(--bs-primary)"><div class="text-primary small">Autorizada</div><div class="fs-4 fw-bold text-primary"><%= stats.autorizadas %></div></div>
      <div class="d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="pipeline-step flex-fill" style="border-color:var(--orange)"><div style="color:var(--orange)" class="small">Evaluada</div><div class="fs-4 fw-bold" style="color:var(--orange)"><%= stats.evaluadas %></div></div>
      <div class="d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="pipeline-step flex-fill" style="border-color:var(--green)"><div style="color:var(--green)" class="small">Liquidada</div><div class="fs-4 fw-bold" style="color:var(--green)"><%= stats.liquidadas %></div></div>
      <% if (stats.rechazadas > 0) { %>
      <div class="d-flex align-items-center"><span class="text-muted">|</span></div>
      <div class="pipeline-step flex-fill" style="border-color:var(--coral)"><div style="color:var(--coral)" class="small">Rechazada</div><div class="fs-4 fw-bold" style="color:var(--coral)"><%= stats.rechazadas %></div></div>
      <% } %>
    </div>
  </div>
</div>

<% if (proxVencer.length > 0) { %>
<div class="alert alert-warning d-flex align-items-start gap-2">
  <i class="bi bi-exclamation-triangle-fill mt-1"></i>
  <div><strong>Acciones por vencer plazo 60 dias:</strong>
    <ul class="mb-0 mt-1"><% proxVencer.forEach(a => { %>
      <li><a href="/franquicia/<%= a.id %>" class="fw-bold"><%= a.empresa_nombre %></a> — <%= a.profile_name %> — <strong><%= Math.ceil(a.dias_restantes) %> dias restantes</strong></li>
    <% }) %></ul>
  </div>
</div>
<% } %>

<div class="card"><div class="card-body p-0">
  <table class="table table-hover mb-0">
    <thead><tr><th>Empresa</th><th>RUT</th><th>Perfil</th><th>Tipo</th><th>Inicio</th><th>Termino</th><th>Part.</th><th>Estado</th><th></th></tr></thead>
    <tbody>
      <% if (acciones.length === 0) { %>
        <tr><td colspan="9" class="empty-state"><i class="bi bi-bank"></i>Sin acciones registradas</td></tr>
      <% } else { acciones.forEach(a => {
        const colors = { borrador:'secondary', comunicada:'info', autorizada:'primary', evaluada:'warning', pre_liquidada:'info', liquidada:'success', rechazada:'danger' };
      %>
        <tr>
          <td><a href="/franquicia/<%= a.id %>" class="fw-bold text-decoration-none"><%= a.empresa_nombre %></a></td>
          <td class="text-muted"><%= a.empresa_rut %></td>
          <td><%= a.profile_code || '' %> <%= a.profile_name || '-' %></td>
          <td><span class="badge bg-secondary"><%= a.tipo %></span></td>
          <td class="text-muted"><%= a.fecha_inicio || '-' %></td>
          <td class="text-muted"><%= a.fecha_termino || '-' %></td>
          <td><span class="badge bg-primary"><%= a.participantes_count %></span></td>
          <td><span class="badge bg-<%= colors[a.estado] || 'secondary' %>"><%= a.estado %></span></td>
          <td class="text-end"><a href="/franquicia/<%= a.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
        </tr>
      <% })} %>
    </tbody>
  </table>
</div></div>
<div class="mt-3 text-muted small">
  <i class="bi bi-info-circle"></i> Las acciones deben ser evaluadas y pre-liquidadas dentro de 60 dias corridos desde la fecha de termino.
</div>
<%- include('../partials/footer') %>
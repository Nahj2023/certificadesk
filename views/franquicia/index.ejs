<% const title = 'Franquicia Tributaria SENCE' %>
<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-bank"></i> Franquicia Tributaria — EyCCL SENCE</h4>
  <a href="/franquicia/nueva" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nueva Accion</a>
</div>

<!-- Pipeline de estados -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white"><strong>Pipeline de Acciones</strong></div>
  <div class="card-body">
    <div class="row text-center g-2">
      <div class="col">
        <div class="border rounded p-2">
          <div class="text-muted small">Borrador</div>
          <div class="fs-4 fw-bold"><%= stats.borrador %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-info">
          <div class="text-info small">Comunicada</div>
          <div class="fs-4 fw-bold text-info"><%= stats.comunicadas %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-primary">
          <div class="text-primary small">Autorizada</div>
          <div class="fs-4 fw-bold text-primary"><%= stats.autorizadas %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-warning">
          <div class="text-warning small">Evaluada</div>
          <div class="fs-4 fw-bold text-warning"><%= stats.evaluadas %></div>
        </div>
      </div>
      <div class="col-auto d-flex align-items-center"><i class="bi bi-arrow-right text-muted"></i></div>
      <div class="col">
        <div class="border rounded p-2 border-success">
          <div class="text-success small">Liquidada</div>
          <div class="fs-4 fw-bold text-success"><%= stats.liquidadas %></div>
        </div>
      </div>
      <% if (stats.rechazadas > 0) { %>
      <div class="col-auto d-flex align-items-center"><span class="text-muted">|</span></div>
      <div class="col">
        <div class="border rounded p-2 border-danger">
          <div class="text-danger small">Rechazada</div>
          <div class="fs-4 fw-bold text-danger"><%= stats.rechazadas %></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<% if (proxVencer.length > 0) { %>
<div class="alert alert-warning">
  <i class="bi bi-exclamation-triangle-fill"></i> <strong>Acciones por vencer plazo 60 dias:</strong>
  <ul class="mb-0 mt-1">
    <% proxVencer.forEach(a => { %>
    <li><a href="/franquicia/<%= a.id %>"><%= a.empresa_nombre %></a> — <%= a.profile_name %> — <strong><%= Math.ceil(a.dias_restantes) %> dias restantes</strong></li>
    <% }) %>
  </ul>
</div>
<% } %>

<!-- Listado de acciones -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><strong>Acciones EyCCL (<%= stats.total %>)</strong></div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr><th>Empresa</th><th>RUT</th><th>Perfil</th><th>Tipo</th><th>Inicio</th><th>Termino</th><th>Part.</th><th>Estado</th><th></th></tr></thead>
      <tbody>
        <% if (acciones.length === 0) { %>
          <tr><td colspan="9" class="text-muted text-center py-4">Sin acciones registradas</td></tr>
        <% } else { acciones.forEach(a => {
          const colors = { borrador:'secondary', comunicada:'info', autorizada:'primary', evaluada:'warning', pre_liquidada:'info', liquidada:'success', rechazada:'danger' };
        %>
          <tr>
            <td><a href="/franquicia/<%= a.id %>" style="text-decoration:none"><%= a.empresa_nombre %></a></td>
            <td><%= a.empresa_rut %></td>
            <td><%= a.profile_code || '' %> <%= a.profile_name || '-' %></td>
            <td><%= a.tipo %></td>
            <td><%= a.fecha_inicio || '-' %></td>
            <td><%= a.fecha_termino || '-' %></td>
            <td><%= a.participantes_count %></td>
            <td><span class="badge bg-<%= colors[a.estado] || 'secondary' %>"><%= a.estado %></span></td>
            <td><a href="/franquicia/<%= a.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
          </tr>
        <% })} %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-3 text-muted small">
  <i class="bi bi-info-circle"></i> Las acciones deben ser evaluadas y pre-liquidadas dentro de 60 dias corridos desde la fecha de termino.
  <br>Ref: <a href="https://sence.gob.cl/empresas/franquicia/tramites_servicios/evaluacion-y-certificacion-de-competencias-laborales-para-empresas" target="_blank">SENCE — EyCCL Franquicia Tributaria</a>
</div>

<%- include('../partials/footer') %>

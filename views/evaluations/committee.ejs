<% const title = 'Comite de Certificacion' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Comite de Decision — Certificacion</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 1.3 — Comite de decision D016</span>
  </div>
  <% if (decision) { %><a href="/docs/acta/<%= decision.id %>" target="_blank" class="btn btn-outline-success"><i class="bi bi-eye"></i> Ver</a>
  <a href="/docs/pdf/acta/<%= decision.id %>" class="btn btn-success"><i class="bi bi-file-earmark-pdf"></i> PDF</a><% } %>
  <a href="/evaluaciones" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<div class="row g-4">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header"><i class="bi bi-clipboard-data me-2" style="color:var(--coral)"></i> Datos de la Evaluacion</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <tr><td class="text-muted" style="width:35%">Candidato</td><td class="fw-bold"><%= evaluation.candidate_name %></td></tr>
          <tr><td class="text-muted">RUT</td><td><%= evaluation.candidate_rut || '-' %></td></tr>
          <tr><td class="text-muted">Perfil</td><td><%= evaluation.profile_name || '-' %></td></tr>
          <tr><td class="text-muted">Evaluador</td><td><%= evaluation.evaluator_name || '-' %></td></tr>
          <tr><td class="text-muted">Fecha</td><td><%= evaluation.scheduled_date || '-' %></td></tr>
          <tr><td class="text-muted">Tipo</td><td><%= evaluation.type %></td></tr>
          <tr><td class="text-muted">Resultado</td><td><span class="badge bg-<%= evaluation.result === 'competente' ? 'success' : 'danger' %>"><%= evaluation.result %></span></td></tr>
          <tr><td class="text-muted">Puntaje</td><td><%= evaluation.score || '-' %></td></tr>
          <tr><td class="text-muted">Observaciones</td><td><%= evaluation.observations || '-' %></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-7">
    <div class="card">
      <div class="card-header"><i class="bi bi-people me-2" style="color:var(--coral)"></i> Decision del Comite</div>
      <div class="card-body">
        <% if (decision) { %>
          <div class="p-4 rounded text-center" style="background:<%= decision.decision === 'certificar' ? 'rgba(46,204,113,0.1)' : 'rgba(232,93,58,0.1)' %>">
            <i class="bi bi-<%= decision.decision === 'certificar' ? 'check-circle-fill text-success' : 'x-circle-fill text-danger' %> display-4"></i>
            <h5 class="mt-2"><%= decision.decision === 'certificar' ? 'CERTIFICAR' : 'NO CERTIFICAR' %></h5>
            <p class="text-muted mb-0">Fecha: <%= decision.committee_date %></p>
            <p class="mt-2"><%= decision.justification %></p>
          </div>
        <% } else { %>
          <form method="POST" action="/evaluaciones/<%= evaluation.id %>/comite">
            <div class="row g-3">
              <div class="col-md-6"><label class="form-label">Fecha del Comite *</label>
                <input type="date" name="committee_date" class="form-control" value="<%= new Date().toISOString().substring(0,10) %>" required>
              </div>
              <div class="col-md-6"><label class="form-label">Recomendacion Evaluador</label>
                <select name="evaluator_recommendation" class="form-select">
                  <option value="competente" <%= evaluation.result === 'competente' ? 'selected' : '' %>>Competente</option>
                  <option value="aun_no_competente" <%= evaluation.result !== 'competente' ? 'selected' : '' %>>Aun No Competente</option>
                </select>
              </div>
              <div class="col-12"><label class="form-label">Miembros del Comite *</label>
                <textarea name="members" class="form-control" rows="3" placeholder="Nombre - Rol (uno por linea)" required></textarea>
                <small class="text-muted">Ej: Juan Perez - Coordinador CEC</small>
              </div>
              <div class="col-md-6"><label class="form-label">Estado de Auditoria</label>
                <select name="audit_status" class="form-select">
                  <option value="sin_auditoria">Sin auditoria</option>
                  <option value="aprobado">Aprobada</option>
                  <option value="observado">Con observaciones</option>
                </select>
              </div>
              <div class="col-md-6 d-flex align-items-end">
                <div class="form-check"><input type="checkbox" name="portfolio_reviewed" value="1" class="form-check-input" id="portfolio">
                  <label for="portfolio" class="form-check-label">Portafolio de evidencias revisado</label>
                </div>
              </div>
              <div class="col-12">
                <label class="form-label fw-bold">Decision del Comite *</label>
                <div class="d-flex gap-4">
                  <div class="form-check">
                    <input type="radio" name="decision" value="certificar" class="form-check-input" id="dec_cert" required>
                    <label for="dec_cert" class="form-check-label text-success fw-bold fs-5">Certificar</label>
                  </div>
                  <div class="form-check">
                    <input type="radio" name="decision" value="no_certificar" class="form-check-input" id="dec_no">
                    <label for="dec_no" class="form-check-label text-danger fw-bold fs-5">No Certificar</label>
                  </div>
                </div>
              </div>
              <div class="col-12"><label class="form-label">Justificacion *</label>
                <textarea name="justification" class="form-control" rows="3" required placeholder="Fundamento de la decision..."></textarea>
              </div>
            </div>
            <div class="mt-4 d-flex gap-2">
              <button type="submit" class="btn btn-primary" onclick="return confirm('Confirmar decision del comite?')"><i class="bi bi-check-circle"></i> Registrar Decision</button>
              <a href="/evaluaciones" class="btn btn-outline-secondary">Cancelar</a>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
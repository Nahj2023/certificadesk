<% const title = conflict ? 'Editar Conflicto' : 'Nueva Declaracion' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><%= title %></h4>
  <a href="/conflictos" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<div class="card border-0 shadow-sm"><div class="card-body">
  <form method="POST" action="/conflictos<%= conflict ? '/'+conflict.id : '' %>">
    <div class="row g-3">
      <div class="col-md-6"><label class="form-label">Evaluador *</label>
        <select name="evaluator_id" class="form-select" required>
          <option value="">Seleccionar...</option>
          <% evaluators.forEach(e => { %><option value="<%= e.id %>" <%= conflict && conflict.evaluator_id==e.id ? 'selected' : '' %>><%= e.name %></option><% }) %>
        </select>
      </div>
      <div class="col-md-6"><label class="form-label">Candidato involucrado</label>
        <select name="candidate_id" class="form-select">
          <option value="">Ninguno / General</option>
          <% candidates.forEach(c => { %><option value="<%= c.id %>" <%= conflict && conflict.candidate_id==c.id ? 'selected' : '' %>><%= c.name %></option><% }) %>
        </select>
      </div>
      <div class="col-md-4"><label class="form-label">Tipo de conflicto *</label>
        <select name="type" class="form-select" required>
          <option value="parentesco" <%= conflict && conflict.type==='parentesco' ? 'selected' : '' %>>Parentesco</option>
          <option value="laboral" <%= conflict && conflict.type==='laboral' ? 'selected' : '' %>>Relacion laboral</option>
          <option value="comercial" <%= conflict && conflict.type==='comercial' ? 'selected' : '' %>>Relacion comercial</option>
          <option value="academico" <%= conflict && conflict.type==='academico' ? 'selected' : '' %>>Relacion academica</option>
          <option value="otro" <%= conflict && conflict.type==='otro' ? 'selected' : '' %>>Otro</option>
        </select>
      </div>
      <div class="col-md-4"><label class="form-label">Fecha declaracion</label>
        <input type="date" name="declaration_date" class="form-control" value="<%= conflict ? conflict.declaration_date || '' : new Date().toISOString().substring(0,10) %>">
      </div>
      <% if (conflict) { %>
      <div class="col-md-4"><label class="form-label">Estado</label>
        <select name="status" class="form-select">
          <option value="declarado" <%= conflict.status==='declarado' ? 'selected' : '' %>>Declarado</option>
          <option value="resuelto" <%= conflict.status==='resuelto' ? 'selected' : '' %>>Resuelto</option>
          <option value="rechazado" <%= conflict.status==='rechazado' ? 'selected' : '' %>>Rechazado</option>
        </select>
      </div>
      <% } %>
      <div class="col-12"><label class="form-label">Descripcion del conflicto</label>
        <textarea name="description" class="form-control" rows="3" placeholder="Describir la relacion o situacion que genera el conflicto..."><%= conflict ? conflict.description || '' : '' %></textarea>
      </div>
      <% if (conflict) { %>
      <div class="col-12"><label class="form-label">Accion tomada</label>
        <textarea name="action_taken" class="form-control" rows="3" placeholder="Ej: Reasignacion de evaluador..."><%= conflict.action_taken || '' %></textarea>
      </div>
      <% } %>
    </div>
    <div class="mt-4"><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> <%= conflict ? 'Actualizar' : 'Registrar Declaracion' %></button></div>
  </form>
</div></div>
<%- include('../partials/footer') %>

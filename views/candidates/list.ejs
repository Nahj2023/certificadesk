<% const title = 'Candidatos' %>
<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Candidatos</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 1 — Proceso de Certificacion</span>
  </div>
  <a href="/candidatos/nuevo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Candidato</a>
</div>

<div class="card mb-3">
  <div class="card-body py-2 px-3">
    <form method="GET" class="row g-2 align-items-center">
      <div class="col-md-4">
        <input type="text" name="q" class="form-control form-control-sm" placeholder="Buscar por nombre, RUT o email..." value="<%= filters.q || '' %>">
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">Todos los estados</option>
          <% statuses.forEach(s => { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1).replace('_', ' ') %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-sm btn-primary">Filtrar</button>
        <a href="/candidatos" class="btn btn-sm btn-outline-secondary">Limpiar</a>
      </div>
      <div class="col-auto ms-auto">
        <span class="badge bg-secondary"><%= candidates.length %> candidato(s)</span>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr><th>Nombre</th><th>RUT</th><th>Perfil</th><th>Estado</th><th>Registro</th><th></th></tr>
      </thead>
      <tbody>
        <% if (candidates.length === 0) { %>
          <tr><td colspan="6" class="empty-state"><i class="bi bi-person-x"></i>No hay candidatos registrados</td></tr>
        <% } else { candidates.forEach(c => { %>
          <tr>
            <td><a href="/candidatos/<%= c.id %>" style="font-weight:600"><%= c.name %></a></td>
            <td class="text-muted"><%= c.rut || '-' %></td>
            <td><%= c.profile_name || '<span class="text-muted">—</span>' %></td>
            <td>
              <%
                const sc = {registrado:'secondary', elegible:'info', evaluando:'warning', pendiente_comite:'primary', certificado:'success', no_certificado:'danger', apelacion:'dark'};
              %>
              <span class="badge bg-<%= sc[c.status] || 'secondary' %>"><%= c.status.replace('_',' ') %></span>
            </td>
            <td class="text-muted"><%= c.created_at ? c.created_at.substring(0,10) : '-' %></td>
            <td class="text-end">
              <a href="/candidatos/<%= c.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
              <a href="/candidatos/<%= c.id %>/editar" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
            </td>
          </tr>
        <% })} %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
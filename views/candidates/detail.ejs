<% const title = candidate.name %>
<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-0"><%= candidate.name %></h4>
    <%
      const statusColors = { registrado:'secondary', elegible:'info', evaluando:'warning', pendiente_comite:'primary', certificado:'success', no_certificado:'danger', apelacion:'dark' };
      const statusColor = statusColors[candidate.status] || 'secondary';
    %>
    <span class="badge bg-<%= statusColor %> mt-1"><%= candidate.status.replace('_',' ') %></span>
  </div>
  <div class="d-flex gap-2">
    <% if (candidate.status === 'certificado') { %>
      <a href="/docs/certificado/<%= candidate.id %>" target="_blank" class="btn btn-sm btn-outline-success"><i class="bi bi-eye"></i> Ver</a>
      <a href="/docs/pdf/certificado/<%= candidate.id %>" class="btn btn-sm btn-success"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
    <% } %>
    <a href="/candidatos/<%= candidate.id %>/editar" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Editar</a>
    <a href="/candidatos" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    <div class="dropdown">
      <button class="btn btn-sm btn-outline-warning dropdown-toggle" data-bs-toggle="dropdown"><i class="bi bi-robot me-1"></i> Consultar IA</button>
      <ul class="dropdown-menu">
        <li><a class="dropdown-item" href="/agentes/1/chat?context=/candidatos/<%= candidate.id %>"><i class="bi bi-book me-1"></i> Norma — Normativa</a></li>
        <li><a class="dropdown-item" href="/agentes/2/chat?context=/candidatos/<%= candidate.id %>"><i class="bi bi-clipboard-check me-1"></i> Eva — Evaluacion</a></li>
      </ul>
    </div>
  </div>
</div>

<% if (typeof req !== 'undefined' && req.query && req.query.error === 'elegibilidad') { %>
<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Debe marcar todos los requisitos obligatorios de elegibilidad.</div>
<% } %>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" role="tablist">
  <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-info" role="tab"><i class="bi bi-person me-1"></i> Informacion</a></li>
  <% if (candidate.status === 'registrado') { %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-elegibilidad" role="tab"><i class="bi bi-check2-square me-1"></i> Elegibilidad</a></li>
  <% } %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-evaluaciones" role="tab"><i class="bi bi-clipboard-check me-1"></i> Evaluaciones <% if (evaluations.length) { %><span class="badge bg-secondary ms-1"><%= evaluations.length %></span><% } %></a></li>
  <% if (decisions && decisions.length > 0) { %>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-decisiones" role="tab"><i class="bi bi-people me-1"></i> Comite <span class="badge bg-secondary ms-1"><%= decisions.length %></span></a></li>
  <% } %>
</ul>

<div class="tab-content">
  <!-- Tab: Info -->
  <div class="tab-pane fade show active" id="tab-info" role="tabpanel">
    <div class="row g-3">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header"><strong>Datos del Candidato</strong></div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tr><th style="width:35%">RUT</th><td><%= candidate.rut || '-' %></td></tr>
              <tr><th>Email</th><td><%= candidate.email || '-' %></td></tr>
              <tr><th>Telefono</th><td><%= candidate.phone || '-' %></td></tr>
              <tr><th>Region</th><td><%= candidate.region || '-' %></td></tr>
              <tr><th>Educacion</th><td><%= candidate.education_level || '-' %></td></tr>
              <tr><th>Experiencia</th><td><%= candidate.work_experience_years %> anos</td></tr>
              <tr><th>Perfil</th><td><%= candidate.profile_name || '-' %></td></tr>
              <tr><th>Registro</th><td><%= candidate.created_at ? candidate.created_at.substring(0,10) : '-' %></td></tr>
            </table>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <% if (candidate.charla_informativa || candidate.entrevista_inicial) { %>
        <div class="card">
          <div class="card-header"><strong><i class="bi bi-info-circle me-1"></i> Datos de Elegibilidad</strong></div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <% if (candidate.charla_informativa) { %><tr><th style="width:40%">Charla Informativa</th><td><%= candidate.charla_informativa %></td></tr><% } %>
              <% if (candidate.entrevista_inicial) { %><tr><th>Entrevista Inicial</th><td><%= candidate.entrevista_inicial %></td></tr><% } %>
              <tr><th>Cedula Identidad</th><td><%= candidate.cedula_identidad ? '<i class="bi bi-check-circle text-success"></i> Si' : '<i class="bi bi-x-circle text-danger"></i> No' %></td></tr>
              <tr><th>CV Entregado</th><td><%= candidate.cv_entregado ? '<i class="bi bi-check-circle text-success"></i> Si' : '<i class="bi bi-x-circle text-danger"></i> No' %></td></tr>
              <tr><th>Carta Compromiso</th><td><%= candidate.carta_compromiso ? '<i class="bi bi-check-circle text-success"></i> Si' : '<i class="bi bi-x-circle text-danger"></i> No' %></td></tr>
              <tr><th>Aut. ChileValora</th><td><%= candidate.autorizacion_chilevalora ? '<i class="bi bi-check-circle text-success"></i> Si' : '<i class="bi bi-x-circle text-danger"></i> No' %></td></tr>
              <tr><th>Aut. Jefatura</th><td><%= candidate.autorizacion_jefe ? '<i class="bi bi-check-circle text-success"></i> Si' : '<i class="bi bi-x-circle text-danger"></i> No' %></td></tr>
              <% if (candidate.informe_elegibilidad) { %><tr><th>Informe</th><td><%= candidate.informe_elegibilidad %></td></tr><% } %>
            </table>
          </div>
        </div>
        <% } %>
        <% if (candidate.notes) { %>
        <div class="card mt-3">
          <div class="card-header"><strong>Notas</strong></div>
          <div class="card-body"><%= candidate.notes %></div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (candidate.status === 'registrado') { %>
  <!-- Tab: Elegibilidad -->
  <div class="tab-pane fade" id="tab-elegibilidad" role="tabpanel">
    <div class="card">
      <div class="card-header"><strong><i class="bi bi-check2-square me-1"></i> Verificacion de Elegibilidad (D016 Proc. 1.1)</strong></div>
      <div class="card-body">
        <form method="POST" action="/candidatos/<%= candidate.id %>/elegibilidad">
          <p class="text-muted small">Segun Manual del Candidato, complete las etapas de elegibilidad:</p>

          <h6 class="mt-3 mb-2"><i class="bi bi-calendar-event"></i> Etapa Informativa</h6>
          <div class="row mb-2">
            <div class="col-6">
              <label class="form-label small">Fecha Charla Informativa</label>
              <input type="date" name="charla_informativa" class="form-control form-control-sm">
            </div>
            <div class="col-6">
              <label class="form-label small">Fecha Entrevista Inicial</label>
              <input type="date" name="entrevista_inicial" class="form-control form-control-sm">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label small">Notas Entrevista</label>
            <textarea name="entrevista_notas" class="form-control form-control-sm" rows="2" placeholder="Observaciones de la entrevista inicial..."></textarea>
          </div>

          <h6 class="mb-2"><i class="bi bi-file-earmark-text"></i> Documentacion</h6>
          <div class="form-check mb-1">
            <input type="checkbox" name="cedula_identidad" value="1" class="form-check-input" id="chkCI">
            <label for="chkCI" class="form-check-label">Copia cedula de identidad entregada</label>
          </div>
          <div class="form-check mb-1">
            <input type="checkbox" name="cv_entregado" value="1" class="form-check-input" id="chkCV">
            <label for="chkCV" class="form-check-label">CV entregado (formato CEC)</label>
          </div>
          <div class="form-check mb-1">
            <input type="checkbox" name="carta_compromiso" value="1" class="form-check-input" id="chkCC">
            <label for="chkCC" class="form-check-label">Carta de compromiso firmada</label>
          </div>
          <div class="form-check mb-1">
            <input type="checkbox" name="autorizacion_chilevalora" value="1" class="form-check-input" id="chkCV2">
            <label for="chkCV2" class="form-check-label">Autorizacion publicacion datos ChileValora</label>
          </div>
          <div class="form-check mb-3">
            <input type="checkbox" name="autorizacion_jefe" value="1" class="form-check-input" id="chkAJ">
            <label for="chkAJ" class="form-check-label">Autorizacion resultado a jefatura</label>
          </div>

          <h6 class="mb-2"><i class="bi bi-shield-check"></i> Requisitos Obligatorios</h6>
          <div class="form-check mb-1">
            <input type="checkbox" name="perfil_verificado" value="1" class="form-check-input" id="chk1" required>
            <label for="chk1" class="form-check-label">Perfil ocupacional verificado <span class="text-danger">*</span></label>
          </div>
          <div class="form-check mb-1">
            <input type="checkbox" name="requisitos_cumplidos" value="1" class="form-check-input" id="chk2" required>
            <label for="chk2" class="form-check-label">Requisitos del perfil cumplidos <span class="text-danger">*</span></label>
          </div>
          <div class="form-check mb-1">
            <input type="checkbox" name="documentacion_ok" value="1" class="form-check-input" id="chk3" required>
            <label for="chk3" class="form-check-label">Documentacion de identidad OK <span class="text-danger">*</span></label>
          </div>
          <div class="form-check mb-3">
            <input type="checkbox" name="sin_conflictos" value="1" class="form-check-input" id="chk4" required>
            <label for="chk4" class="form-check-label">Sin conflictos de interes <span class="text-danger">*</span></label>
          </div>

          <div class="mb-3">
            <label class="form-label small">Informe de Elegibilidad (observaciones)</label>
            <textarea name="informe_elegibilidad" class="form-control form-control-sm" rows="2" placeholder="Conclusion del informe de elegibilidad..."></textarea>
          </div>

          <button type="submit" class="btn btn-info text-white" onclick="return confirm('Marcar candidato como elegible?')">
            <i class="bi bi-check-circle"></i> Marcar Elegible
          </button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Tab: Evaluaciones -->
  <div class="tab-pane fade" id="tab-evaluaciones" role="tabpanel">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Historial de Evaluaciones</strong>
        <span class="badge bg-secondary"><%= evaluations.length %></span>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Fecha</th><th>Evaluador</th><th>Tipo</th><th>Ponderado</th><th>Resultado</th><th></th></tr></thead>
          <tbody>
            <% if (evaluations.length === 0) { %>
              <tr><td colspan="6" class="text-muted text-center py-4"><i class="bi bi-clipboard-x" style="font-size:1.5rem"></i><br>Sin evaluaciones</td></tr>
            <% } else { evaluations.forEach(e => { %>
              <tr>
                <td><a href="/evaluaciones/<%= e.id %>"><%= e.scheduled_date || '-' %></a></td>
                <td><%= e.evaluator_name || '-' %></td>
                <td><%= e.type || '-' %></td>
                <td><strong><%= e.score_ponderado ? e.score_ponderado.toFixed(2) : (e.score || '-') %></strong></td>
                <td><span class="badge bg-<%= e.result === 'competente' ? 'success' : e.result === 'aun_no_competente' ? 'danger' : 'secondary' %>"><%= e.result || e.status %></span></td>
                <td class="text-end">
                  <a href="/evaluaciones/<%= e.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                </td>
              </tr>
            <% })} %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if (decisions && decisions.length > 0) { %>
  <!-- Tab: Decisiones Comite -->
  <div class="tab-pane fade" id="tab-decisiones" role="tabpanel">
    <div class="card">
      <div class="card-header"><strong>Decisiones del Comite</strong></div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead><tr><th>Fecha</th><th>Decision</th><th>Justificacion</th><th>Por</th></tr></thead>
          <tbody>
            <% decisions.forEach(d => { %>
            <tr>
              <td><%= d.committee_date || '-' %></td>
              <td><span class="badge bg-<%= d.decision === 'certificar' ? 'success' : 'danger' %> fs-6"><%= d.decision %></span></td>
              <td class="text-muted" style="max-width:300px"><%= d.justification || '-' %></td>
              <td><%= d.decided_by_name || '-' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>
</div>

<div class="mt-4">
  <form method="POST" action="/candidatos/<%= candidate.id %>/eliminar" onsubmit="return confirm('Eliminar este candidato?')">
    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Eliminar candidato</button>
  </form>
</div>

<%- include('../partials/footer') %>

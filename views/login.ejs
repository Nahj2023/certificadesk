<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ingresar | CertificaDesk</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #1a1d23; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { max-width: 400px; width: 100%; background: #fff; border-radius: 12px; padding: 2.5rem; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .login-card h2 { color: #1a1d23; font-weight: 700; }
    .login-card .subtitle { color: #6c757d; font-size: 0.9rem; }
    .btn-primary { background: #2563eb; border-color: #2563eb; }
    .btn-primary:hover { background: #1d4ed8; }
    .brand { color: #fff; text-align: center; margin-bottom: 2rem; }
    .brand h1 { font-size: 2rem; font-weight: 800; letter-spacing: -1px; }
    .brand small { opacity: 0.6; }
  </style>
</head>
<body>
  <div>
    <div class="brand">
      <h1>CertificaDesk</h1>
      <small>Gestion para Centros de Evaluacion y Certificacion</small>
    </div>
    <div class="login-card">
      <h2 class="mb-1">Ingresar</h2>
      <p class="subtitle mb-4">Accede a tu centro de certificacion</p>
      <% if (error) { %>
        <div class="alert alert-danger py-2"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label">Usuario</label>
          <input type="text" name="username" class="form-control" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Contrasena</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">Ingresar</button>
      </form>
      <div class="text-center mt-4">
        <small class="text-muted">JVH Labs &middot; ChileValora</small>
      </div>
    </div>
  </div>
</body>
</html>

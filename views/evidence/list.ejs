<% const title = 'Portafolio de Evidencias' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Portafolio de Evidencias</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 3 — Evidencias por evaluacion D016</span>
  </div>
</div>
<div class="card"><div class="card-body p-0">
  <table class="table table-hover mb-0" data-enhance>
    <thead><tr><th>Candidato</th><th>RUT</th><th>Perfil</th><th>Evaluador</th><th>Fecha</th><th>Estado</th><th>Evidencias</th><th></th></tr></thead>
    <tbody>
      <% if (evaluations.length === 0) { %>
        <tr><td colspan="8" class="empty-state"><i class="bi bi-folder2"></i>Sin evaluaciones registradas</td></tr>
      <% } else { evaluations.forEach(ev => { %>
        <tr>
          <td class="fw-bold"><%= ev.candidate_name %></td>
          <td class="text-muted"><%= decrypt(decrypt(ev.candidate_rut)) || '-' %></td>
          <td><%= ev.profile_name || '-' %></td>
          <td class="text-muted"><%= ev.evaluator_name || '-' %></td>
          <td class="text-muted"><%= ev.scheduled_date || '-' %></td>
          <td>
            <span class="badge bg-<%= ev.status === 'completada' ? 'success' : ev.status === 'en_curso' ? 'primary' : ev.status === 'cancelada' ? 'danger' : 'warning' %>"><%= ev.status %></span>
            <% if (ev.result) { %>
              <span class="badge bg-<%= ev.result === 'competente' ? 'success' : 'danger' %>"><%= ev.result %></span>
            <% } %>
          </td>
          <td><span class="badge bg-<%= ev.evidence_count > 0 ? 'primary' : 'secondary' %>"><%= ev.evidence_count %> archivo<%= ev.evidence_count !== 1 ? 's' : '' %></span></td>
          <td class="text-end"><a href="/evidencias/<%= ev.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open"></i> Ver</a></td>
        </tr>
      <% })} %>
    </tbody>
  </table>
</div></div>
<%- include('../partials/footer') %>
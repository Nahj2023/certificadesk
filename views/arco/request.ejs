<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Derechos ARCO | CertificaDesk</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    body { font-family:'Inter',sans-serif; background:#F3EDE4; min-height:100vh; display:flex; align-items:center; justify-content:center; -webkit-font-smoothing:antialiased; }
    .arco-wrapper { max-width:560px; width:100%; padding:1rem; }
    .brand { text-align:center; margin-bottom:2rem; }
    .brand-logo { width:56px; height:56px; background:#E85D3A; border-radius:16px; display:inline-flex; align-items:center; justify-content:center; margin-bottom:1rem; box-shadow:0 8px 24px rgba(232,93,58,0.25); }
    .brand-logo svg { width:28px; height:28px; fill:#fff; }
    .brand h1 { font-size:1.5rem; font-weight:800; color:#2D3436; letter-spacing:-0.03em; margin-bottom:0.25rem; }
    .brand p { color:#636E72; font-size:0.85rem; }
    .arco-card { background:#fff; border-radius:20px; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.06); }
    .arco-card h2 { font-size:1.2rem; font-weight:700; color:#2D3436; margin-bottom:0.25rem; }
    .arco-card .subtitle { color:#636E72; font-size:0.82rem; margin-bottom:1.5rem; line-height:1.5; }
    .form-label { font-size:0.78rem; font-weight:600; color:#636E72; text-transform:uppercase; letter-spacing:0.04em; }
    .form-control,.form-select { border:1.5px solid #DFE6E9; border-radius:10px; padding:0.65rem 1rem; font-size:0.9rem; transition:all 0.2s ease; }
    .form-control:focus,.form-select:focus { border-color:#E85D3A; box-shadow:0 0 0 3px rgba(232,93,58,0.08); }
    .btn-arco { background:#E85D3A; border:none; color:#fff; border-radius:10px; padding:0.7rem 1rem; font-weight:600; font-size:0.9rem; width:100%; }
    .btn-arco:hover { background:#D14E2E; color:#fff; }
    .alert-danger { background:rgba(231,76,60,0.08); border:none; color:#E74C3C; border-radius:10px; font-size:0.85rem; }
    .alert-success { background:rgba(0,184,148,0.08); border:none; color:#00B894; border-radius:10px; }
    .footer-text { text-align:center; margin-top:2rem; font-size:0.75rem; color:#B2BEC3; }
    .footer-text a { color:#E85D3A; text-decoration:none; }
    .arco-types { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:1rem; }
    .arco-type { display:flex; align-items:center; gap:8px; padding:10px 14px; border:1.5px solid #DFE6E9; border-radius:10px; cursor:pointer; transition:all 0.2s; font-size:0.85rem; }
    .arco-type:has(input:checked) { border-color:#E85D3A; background:rgba(232,93,58,0.04); }
    .arco-type input { accent-color:#E85D3A; }
  </style>
</head>
<body>
  <div class="arco-wrapper">
    <div class="brand">
      <div class="brand-logo">
        <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      </div>
      <h1>CertificaDesk</h1>
      <p>Portal de Derechos ARCO — Ley 21.719</p>
    </div>
    <div class="arco-card">
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="text-center py-3">
          <div style="font-size:3rem; color:#00B894; margin-bottom:1rem">&#10003;</div>
          <h2>Solicitud recibida</h2>
          <p class="subtitle">Su solicitud ha sido registrada con el numero de referencia <strong>#<%= refId %></strong>. Responderemos a su email en un plazo maximo de 15 dias habiles conforme a la Ley 21.719.</p>
          <a href="/arco" class="btn btn-arco" style="max-width:200px; display:inline-block">Nueva solicitud</a>
        </div>
      <% } else { %>
        <h2>Ejercer derechos sobre sus datos</h2>
        <p class="subtitle">Conforme a la Ley 21.719 de Proteccion de Datos Personales, usted tiene derecho a acceder, rectificar, cancelar u oponerse al tratamiento de sus datos personales.</p>
        <% if (error) { %>
          <div class="alert alert-danger py-2 mb-3"><%= error %></div>
        <% } %>
        <form method="POST" action="/arco">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label">Nombre completo *</label>
            <input type="text" name="requester_name" class="form-control" required>
          </div>
          <div class="row mb-3">
            <div class="col-6">
              <label class="form-label">RUT</label>
              <input type="text" name="requester_rut" class="form-control" placeholder="12.345.678-9">
            </div>
            <div class="col-6">
              <label class="form-label">Email *</label>
              <input type="email" name="requester_email" class="form-control" required>
            </div>
          </div>
          <label class="form-label">Tipo de solicitud *</label>
          <div class="arco-types">
            <label class="arco-type"><input type="radio" name="type" value="acceso" required> Acceso</label>
            <label class="arco-type"><input type="radio" name="type" value="rectificacion"> Rectificacion</label>
            <label class="arco-type"><input type="radio" name="type" value="cancelacion"> Cancelacion</label>
            <label class="arco-type"><input type="radio" name="type" value="oposicion"> Oposicion</label>
          </div>
          <div class="mb-3">
            <label class="form-label">Descripcion de la solicitud</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Describa los datos que desea consultar, corregir o eliminar"></textarea>
          </div>
          <button type="submit" class="btn btn-arco">Enviar solicitud</button>
        </form>
      <% } %>
    </div>
    <div class="footer-text">
      <a href="/">CertificaDesk</a> por <a href="https://jvh-labs.cl">JVH Labs</a> &middot; <a href="/login">Acceso CEC</a>
    </div>
  </div>
</body>
</html>

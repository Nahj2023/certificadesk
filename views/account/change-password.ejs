<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-5">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-key me-2" style="color:var(--coral)"></i> Cambiar contraseña
      </div>
      <div class="card-body p-4">
        <% if (expired) { %>
          <div class="alert alert-warning py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Su contraseña ha expirado (mas de 90 dias). Debe cambiarla para continuar.
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger py-2 mb-3"><%= error %></div>
        <% } %>
        <form method="POST" action="/mi-cuenta/password">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label">Contraseña actual</label>
            <input type="password" name="current_password" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <input type="password" name="new_password" class="form-control" required minlength="8">
            <div class="form-text">Minimo 8 caracteres, 1 mayuscula, 1 numero</div>
          </div>
          <div class="mb-4">
            <label class="form-label">Confirmar nueva contraseña</label>
            <input type="password" name="confirm_password" class="form-control" required minlength="8">
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cambiar contraseña</button>
            <% if (!expired) { %>
              <a href="/dashboard" class="btn btn-outline-secondary">Cancelar</a>
            <% } %>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

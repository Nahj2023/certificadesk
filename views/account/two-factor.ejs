<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <h4 class="mb-4">Autenticacion de dos factores (2FA)</h4>

    <% if (error) { %>
      <div class="alert alert-danger py-2 mb-3"><%= error %></div>
    <% } %>

    <% if (enabled) { %>
      <!-- 2FA Activo -->
      <div class="card border-success mb-4">
        <div class="card-body text-center py-4">
          <div style="font-size:3rem;color:var(--green)"><i class="bi bi-shield-check"></i></div>
          <h5 class="mt-2 mb-1">2FA Activado</h5>
          <p class="text-muted mb-0" style="font-size:0.88rem">Su cuenta esta protegida con autenticacion de dos factores</p>
        </div>
      </div>
      <div class="card">
        <div class="card-header">Desactivar 2FA</div>
        <div class="card-body">
          <p class="text-muted" style="font-size:0.85rem">Para desactivar 2FA, ingrese su contraseña como confirmacion.</p>
          <form method="POST" action="/mi-cuenta/2fa/disable">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row">
              <div class="col-md-8">
                <input type="password" name="password" class="form-control" placeholder="Contraseña actual" required>
              </div>
              <div class="col-md-4">
                <button type="submit" class="btn btn-outline-danger w-100">Desactivar</button>
              </div>
            </div>
          </form>
        </div>
      </div>

    <% } else if (qrDataUrl) { %>
      <!-- Setup en progreso -->
      <div class="card mb-4">
        <div class="card-header"><i class="bi bi-qr-code me-2" style="color:var(--coral)"></i> Paso 1: Escanear codigo QR</div>
        <div class="card-body text-center">
          <p class="text-muted mb-3" style="font-size:0.85rem">
            Abra su aplicacion autenticadora (Google Authenticator, Authy, etc.) y escanee este codigo:
          </p>
          <img src="<%= qrDataUrl %>" alt="QR Code 2FA" style="max-width:220px;border-radius:12px;border:2px solid #DFE6E9">
          <div class="mt-3">
            <small class="text-muted">Si no puede escanear, ingrese esta clave manualmente:</small>
            <div class="mt-1">
              <code style="font-size:0.9rem;background:#F3EDE4;padding:0.4rem 0.8rem;border-radius:8px;letter-spacing:0.1em"><%= secret %></code>
            </div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><i class="bi bi-check-circle me-2" style="color:var(--coral)"></i> Paso 2: Verificar codigo</div>
        <div class="card-body">
          <p class="text-muted mb-3" style="font-size:0.85rem">
            Ingrese el codigo de 6 digitos que muestra la aplicacion para confirmar la configuracion:
          </p>
          <form method="POST" action="/mi-cuenta/2fa/verify">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="row">
              <div class="col-md-6">
                <input type="text" name="totp_code" class="form-control" maxlength="6" pattern="[0-9]{6}" required autofocus
                  style="font-size:1.5rem;letter-spacing:0.4em;text-align:center;font-weight:700"
                  placeholder="000000" inputmode="numeric" autocomplete="one-time-code">
              </div>
              <div class="col-md-6 d-flex align-items-start">
                <button type="submit" class="btn btn-primary"><i class="bi bi-shield-check"></i> Activar 2FA</button>
              </div>
            </div>
          </form>
        </div>
      </div>

    <% } else { %>
      <!-- 2FA no configurado -->
      <div class="card mb-4">
        <div class="card-body text-center py-4">
          <div style="font-size:3rem;color:#B2BEC3"><i class="bi bi-shield"></i></div>
          <h5 class="mt-2 mb-1">2FA no configurado</h5>
          <p class="text-muted mb-0" style="font-size:0.88rem">
            Proteja su cuenta con un segundo factor de autenticacion usando Google Authenticator u otra app compatible con TOTP.
          </p>
        </div>
      </div>
      <form method="POST" action="/mi-cuenta/2fa/setup">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary"><i class="bi bi-qr-code me-1"></i> Configurar 2FA</button>
      </form>
    <% } %>

    <div class="mt-3">
      <a href="/dashboard" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

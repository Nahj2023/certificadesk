<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <h4 class="mb-4">Retencion de datos</h4>

    <div class="card mb-4">
      <div class="card-header"><i class="bi bi-gear me-2" style="color:var(--coral)"></i> Configuracion</div>
      <div class="card-body">
        <form method="POST" action="/admin/retencion">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="row align-items-end">
            <div class="col-md-4">
              <label class="form-label">Anos de retencion</label>
              <input type="number" name="retention_years" class="form-control" min="1" max="20" value="<%= retention_years %>">
              <div class="form-text">Datos personales se anonimizaran despues de este periodo</div>
            </div>
            <div class="col-md-4">
              <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header"><i class="bi bi-clock-history me-2" style="color:var(--coral)"></i> Estado actual</div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <div class="border rounded p-3 text-center">
              <div style="font-size:2rem; font-weight:800; color:var(--coral)"><%= stats.total %></div>
              <small class="text-muted">Candidatos total</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3 text-center">
              <div style="font-size:2rem; font-weight:800; color:var(--orange)"><%= stats.expired %></div>
              <small class="text-muted">Superan retencion</small>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-3 text-center">
              <div style="font-size:2rem; font-weight:800; color:var(--green)"><%= stats.anonymized %></div>
              <small class="text-muted">Ya anonimizados</small>
            </div>
          </div>
        </div>
        <% if (stats.expired > 0) { %>
        <div class="mt-3">
          <form method="POST" action="/admin/retencion/ejecutar">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-warning" data-confirm="Se anonimizaran <%= stats.expired %> candidatos que superan el periodo de retencion. Esta accion es irreversible.">
              <i class="bi bi-shield-exclamation"></i> Anonimizar <%= stats.expired %> registro<%= stats.expired !== 1 ? 's' : '' %> vencidos
            </button>
          </form>
        </div>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><i class="bi bi-journal-text me-2" style="color:var(--coral)"></i> Registro de tratamiento (Art. 14 ter)</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0" style="font-size:0.85rem">
          <thead>
            <tr><th>Fecha</th><th>Usuario</th><th>Accion</th><th>Entidad</th><th>Campos</th><th>Proposito</th><th>IP</th></tr>
          </thead>
          <tbody>
            <% treatments.forEach(t => { %>
            <tr>
              <td style="white-space:nowrap"><%= new Date(t.created_at).toLocaleString('es-CL') %></td>
              <td><%= t.user_name || 'Sistema' %></td>
              <td><span class="badge bg-<%= t.action === 'anonymize' ? 'danger' : t.action === 'write' ? 'primary' : 'info' %>"><%= t.action %></span></td>
              <td><%= t.entity_type %> #<%= t.entity_id || '' %></td>
              <td><code style="font-size:0.75rem"><%= t.fields_accessed || '—' %></code></td>
              <td><%= t.purpose || '—' %></td>
              <td><code style="font-size:0.75rem"><%= t.ip || '—' %></code></td>
            </tr>
            <% }); %>
            <% if (treatments.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-3">Sin registros de tratamiento</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

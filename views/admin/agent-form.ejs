<% const title = agent ? 'Editar Agente' : 'Nuevo Agente' %>
<%- include('../partials/header', { title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><%= agent ? agent.avatar || '🤖' : '🤖' %> <%= title %></h4>
  <a href="/admin/agentes" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<form method="POST" action="/admin/agentes/<%= agent ? agent.id : '' %>">
  <div class="row g-3">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="mb-3">Informacion General</h6>
          <div class="mb-3">
            <label class="form-label small">Codigo</label>
            <input type="text" name="code" class="form-control" value="<%= agent ? agent.code : '' %>" required pattern="[a-z0-9_-]+" placeholder="mi-agente">
          </div>
          <div class="mb-3">
            <label class="form-label small">Nombre</label>
            <input type="text" name="name" class="form-control" value="<%= agent ? agent.name : '' %>" required placeholder="Nombre — Descripcion corta">
          </div>
          <div class="mb-3">
            <label class="form-label small">Avatar (emoji)</label>
            <input type="text" name="avatar" class="form-control" value="<%= agent ? agent.avatar : '🤖' %>" style="font-size:1.5rem" maxlength="4">
          </div>
          <div class="mb-3">
            <label class="form-label small">Descripcion</label>
            <textarea name="description" class="form-control" rows="2"><%= agent ? agent.description : '' %></textarea>
          </div>
          <div class="row">
            <div class="col-6 mb-3">
              <label class="form-label small">Modelo</label>
              <select name="model" class="form-select">
                <option value="llama-3.3-70b-versatile" <%= agent && agent.model === 'llama-3.3-70b-versatile' ? 'selected' : '' %>>Llama 3.3 70B</option>
                <option value="llama-3.1-8b-instant" <%= agent && agent.model === 'llama-3.1-8b-instant' ? 'selected' : '' %>>Llama 3.1 8B (rapido)</option>
                <option value="meta-llama/llama-4-scout-17b-16e-instruct" <%= agent && agent.model && agent.model.includes('scout') ? 'selected' : '' %>>Llama 4 Scout</option>
              </select>
            </div>
            <div class="col-3 mb-3">
              <label class="form-label small">Temperatura</label>
              <input type="number" name="temperature" class="form-control" value="<%= agent ? agent.temperature : 0.3 %>" min="0" max="1" step="0.1">
            </div>
            <div class="col-3 mb-3">
              <label class="form-label small">Max Tokens</label>
              <input type="number" name="max_tokens" class="form-control" value="<%= agent ? agent.max_tokens : 2048 %>" min="256" max="4096" step="256">
            </div>
          </div>
          <div class="row">
            <div class="col-6">
              <div class="form-check form-switch">
                <input type="checkbox" name="is_public" class="form-check-input" id="isPublic" value="1" <%= agent && agent.is_public ? 'checked' : '' %>>
                <label class="form-check-label small" for="isPublic">Agente publico (sin login)</label>
              </div>
            </div>
            <div class="col-6">
              <div class="form-check form-switch">
                <input type="checkbox" name="active" class="form-check-input" id="isActive" value="1" <%= !agent || agent.active ? 'checked' : '' %>>
                <label class="form-check-label small" for="isActive">Activo</label>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h6 class="mb-3">System Prompt</h6>
          <textarea name="system_prompt" class="form-control font-monospace" rows="14" style="font-size:0.8rem" required><%= agent ? agent.system_prompt : '' %></textarea>
          <small class="text-muted"><%= agent ? agent.system_prompt.length : 0 %> caracteres</small>
        </div>
      </div>
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="mb-3">Herramientas (JSON array)</h6>
          <textarea name="tools_enabled" class="form-control font-monospace" rows="3" style="font-size:0.8rem"><%= agent ? agent.tools_enabled : '[]' %></textarea>
          <small class="text-muted">Disponibles: getStats, countEvaluations, getCandidateInfo, getAuditCompliance, listPendingActions, getFormResponses, getEvaluationDetail, getEvidences, runAuditChecklist, generateGapReport, getEvaluatorPerformance</small>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-3 d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Guardar</button>
    <a href="/admin/agentes" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>

<%- include('../partials/footer') %>

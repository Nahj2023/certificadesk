<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <h4 class="mb-4">Alertas de seguridad</h4>

    <% if (alerts.length > 0) { %>
    <div class="card mb-4 border-danger">
      <div class="card-header bg-danger bg-opacity-10">
        <i class="bi bi-exclamation-octagon me-2" style="color:#E74C3C"></i> Anomalias detectadas (<%= alerts.length %>)
      </div>
      <div class="card-body">
        <% alerts.forEach(a => {
          const color = a.severity === 'critica' ? 'danger' : a.severity === 'alta' ? 'warning' : 'info';
        %>
        <div class="alert alert-<%= color %> py-2 mb-2" style="font-size:0.88rem">
          <span class="badge bg-<%= color %> me-2" style="font-size:0.7rem;text-transform:uppercase"><%= a.severity %></span>
          <strong><%= a.type.replace(/_/g, ' ') %>:</strong> <%= a.message %>
        </div>
        <% }); %>
      </div>
    </div>
    <% } else { %>
    <div class="card mb-4 border-success">
      <div class="card-body text-center py-4">
        <div style="font-size:3rem;color:var(--green)"><i class="bi bi-shield-check"></i></div>
        <h5 class="mt-2 mb-1">Sin anomalias detectadas</h5>
        <p class="text-muted mb-0" style="font-size:0.88rem">El sistema no ha detectado patrones sospechosos actualmente</p>
      </div>
    </div>
    <% } %>

    <div class="card">
      <div class="card-header"><i class="bi bi-clock-history me-2" style="color:var(--coral)"></i> Historial de alertas</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0" style="font-size:0.85rem">
          <thead><tr><th>Fecha</th><th>Detalle</th></tr></thead>
          <tbody>
            <% recent.forEach(r => { %>
            <tr>
              <td style="white-space:nowrap;width:180px"><%= new Date(r.created_at).toLocaleString('es-CL') %></td>
              <td><%= r.details %></td>
            </tr>
            <% }); %>
            <% if (recent.length === 0) { %>
            <tr><td colspan="2" class="text-center text-muted py-3">Sin alertas registradas</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-3">
      <small class="text-muted">La deteccion automatica se ejecuta cada 15 minutos. DPO: <%= process.env.DPO_EMAIL || '(no configurado — agregar DPO_EMAIL en .env)' %></small>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

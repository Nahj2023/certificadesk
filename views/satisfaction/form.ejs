<% const title = 'Nueva Encuesta' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Nueva Encuesta de Satisfaccion</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 7 — Registro de encuesta</span>
  </div>
  <a href="/satisfaccion" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<form method="POST" action="/satisfaccion">
  <div class="row g-4">
    <div class="col-md-7">
      <div class="card">
        <div class="card-header"><i class="bi bi-star me-2" style="color:var(--coral)"></i> Puntajes (1 a 5)</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Candidato</label>
              <select name="candidate_id" class="form-select"><option value="">Seleccionar...</option>
                <% candidates.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
              </select>
            </div>
            <div class="col-md-6"><label class="form-label">Satisfaccion General *</label>
              <select name="score_overall" class="form-select" required>
                <option value="5">5 - Excelente</option><option value="4">4 - Bueno</option>
                <option value="3">3 - Regular</option><option value="2">2 - Malo</option>
                <option value="1">1 - Muy malo</option>
              </select>
            </div>
            <div class="col-md-6"><label class="form-label">Evaluador</label>
              <select name="score_evaluator" class="form-select"><option value="">-</option><option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option></select>
            </div>
            <div class="col-md-6"><label class="form-label">Proceso</label>
              <select name="score_process" class="form-select"><option value="">-</option><option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option></select>
            </div>
            <div class="col-md-6"><label class="form-label">Infraestructura</label>
              <select name="score_infrastructure" class="form-select"><option value="">-</option><option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option></select>
            </div>
            <div class="col-md-6"><label class="form-label">Comunicacion</label>
              <select name="score_communication" class="form-select"><option value="">-</option><option value="5">5</option><option value="4">4</option><option value="3">3</option><option value="2">2</option><option value="1">1</option></select>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-5">
      <div class="card h-100">
        <div class="card-header"><i class="bi bi-chat-dots me-2" style="color:var(--coral)"></i> Comentarios</div>
        <div class="card-body">
          <textarea name="comments" class="form-control" rows="8" placeholder="Comentarios adicionales del candidato sobre su experiencia..."></textarea>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-4 d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar Encuesta</button>
    <a href="/satisfaccion" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>
<%- include('../partials/footer') %>
<% const title = 'Evaluadores' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Equipo de Evaluadores</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 2 — Gestion de evaluadores D016</span>
  </div>
  <a href="/evaluadores/nuevo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nuevo Evaluador</a>
</div>
<div class="card"><div class="card-body p-0">
  <table class="table table-hover mb-0" data-enhance>
    <thead><tr><th>Nombre</th><th>RUT</th><th>Especialidades</th><th>Tipo Contrato</th><th>DJS Vence</th><th>Score</th><th>Estado</th></tr></thead>
    <tbody>
      <% if (evaluators.length === 0) { %>
        <tr><td colspan="7" class="empty-state"><i class="bi bi-person-badge"></i>Sin evaluadores registrados</td></tr>
      <% } else { evaluators.forEach(ev => { %>
        <tr>
          <td><a href="/evaluadores/<%= ev.id %>" class="fw-bold text-decoration-none"><%= ev.name %></a></td>
          <td class="text-muted"><%= ev.rut || '-' %></td>
          <td><%= ev.specialties || '-' %></td>
          <td><span class="badge bg-<%= ev.contract_type === 'planta' ? 'primary' : ev.contract_type === 'honorarios' ? 'info' : 'secondary' %>"><%= ev.contract_type || '-' %></span></td>
          <td class="<%= ev.djs_expiry && new Date(ev.djs_expiry) < new Date() ? 'text-danger fw-bold' : 'text-muted' %>"><%= ev.djs_expiry || '-' %></td>
          <td><% if (ev.performance_score > 0) { %>
            <span class="badge bg-<%= ev.performance_score >= 4 ? 'success' : ev.performance_score >= 3 ? 'warning' : 'danger' %>"><%= ev.performance_score.toFixed(1) %></span>
          <% } else { %><span class="text-muted">-</span><% } %></td>
          <td><span class="badge bg-<%= ev.active ? 'success' : 'secondary' %>"><%= ev.active ? 'Activo' : 'Inactivo' %></span></td>
        </tr>
      <% })} %>
    </tbody>
  </table>
</div></div>
<%- include('../partials/footer') %>
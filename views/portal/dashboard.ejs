<% const title = 'Mi Portal' %>
<%- include('../partials/header', { title }) %>

<% if (!evaluator) { %>
<div class="card"><div class="card-body text-center py-5">
  <i class="bi bi-person-x" style="font-size:3rem;color:var(--text-muted)"></i>
  <h5 class="mt-3">Sin perfil de evaluador</h5>
  <p class="text-muted">Tu cuenta no esta vinculada a un perfil de evaluador. Contacta al administrador del CEC.</p>
</div></div>
<% } else { %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1"><i class="bi bi-person-badge" style="color:var(--coral)"></i> Hola, <%= evaluator.name %></h4>
    <span class="text-muted" style="font-size:0.85rem">Portal Evaluador — <%= user.org_name %></span>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <% if (evaluator.djs_expiry) { %>
      <% const djsDays = Math.ceil((new Date(evaluator.djs_expiry) - new Date()) / 86400000); %>
      <span class="badge bg-<%= djsDays < 0 ? 'danger' : djsDays <= 30 ? 'warning' : 'success' %>" style="font-size:0.8rem">
        <i class="bi bi-calendar-check"></i> DJS: <%= evaluator.djs_expiry %> (<%= djsDays < 0 ? 'VENCIDA' : djsDays + 'd' %>)
      </span>
    <% } %>
  </div>
</div>

<!-- Alerts -->
<% if (alerts.length > 0) { %>
<div class="mb-4">
  <% alerts.forEach(a => { %>
  <div class="alert alert-<%= a.type %> d-flex align-items-center gap-2 mb-2 py-2" style="border-radius:var(--card-radius)">
    <i class="bi bi-<%= a.type === 'danger' ? 'exclamation-octagon' : a.type === 'warning' ? 'exclamation-triangle' : 'info-circle' %>"></i>
    <%= a.text %>
  </div>
  <% }) %>
</div>
<% } %>

<!-- Stats -->
<div class="row g-3 mb-4">
  <div class="col-md-3 col-6">
    <div class="card text-center">
      <div class="card-body py-3">
        <div style="font-size:2rem;font-weight:800;color:var(--coral)"><%= stats.total %></div>
        <div style="font-size:0.75rem;text-transform:uppercase;font-weight:700;color:var(--text-secondary)">Total asignadas</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card text-center">
      <div class="card-body py-3">
        <div style="font-size:2rem;font-weight:800;color:var(--orange)"><%= stats.programadas + stats.en_proceso %></div>
        <div style="font-size:0.75rem;text-transform:uppercase;font-weight:700;color:var(--text-secondary)">Pendientes</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card text-center">
      <div class="card-body py-3">
        <div style="font-size:2rem;font-weight:800;color:var(--green)"><%= stats.completadas %></div>
        <div style="font-size:0.75rem;text-transform:uppercase;font-weight:700;color:var(--text-secondary)">Completadas</div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card text-center">
      <div class="card-body py-3">
        <div style="font-size:2rem;font-weight:800;color:var(--teal)"><%= stats.competentes %></div>
        <div style="font-size:0.75rem;text-transform:uppercase;font-weight:700;color:var(--text-secondary)">Competentes</div>
      </div>
    </div>
  </div>
</div>

<!-- Evaluations table -->
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <strong><i class="bi bi-clipboard-check me-2" style="color:var(--coral)"></i> Mis Evaluaciones Asignadas</strong>
    <span class="badge bg-secondary"><%= evaluations.length %></span>
  </div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr>
        <th>Candidato</th><th>Perfil</th><th>Fecha</th><th>Estado</th><th>Resultado</th><th></th>
      </tr></thead>
      <tbody>
        <% if (evaluations.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:1.5rem;opacity:0.3"></i><br>Sin evaluaciones asignadas</td></tr>
        <% } else { evaluations.forEach(e => { %>
        <tr>
          <td class="fw-bold"><%= e.candidate_name %></td>
          <td class="text-muted" style="font-size:0.85rem"><%= e.profile_name || '-' %></td>
          <td class="text-muted"><%= e.scheduled_date || '-' %></td>
          <td>
            <span class="badge bg-<%= e.status === 'completada' ? 'success' : e.status === 'en_proceso' ? 'primary' : e.status === 'programada' ? 'warning' : 'secondary' %>">
              <%= e.status %>
            </span>
          </td>
          <td>
            <% if (e.result) { %>
              <span class="badge bg-<%= e.result === 'competente' ? 'success' : 'danger' %>"><%= e.result %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td><a href="/portal/evaluacion/<%= e.id %>" class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-eye"></i> Ver</a></td>
        </tr>
        <% })} %>
      </tbody>
    </table>
  </div>
</div>

<!-- Quick info -->
<div class="row g-3 mt-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><strong><i class="bi bi-person-vcard me-2" style="color:var(--coral)"></i> Mi Perfil</strong></div>
      <div class="card-body">
        <table class="table table-sm mb-0">
          <tr><td class="text-muted" style="width:40%">Nombre</td><td class="fw-bold"><%= evaluator.name %></td></tr>
          <tr><td class="text-muted">RUT</td><td><%= typeof decrypt !== 'undefined' ? decrypt(evaluator.rut) : evaluator.rut %></td></tr>
          <tr><td class="text-muted">Email</td><td><%= typeof decrypt !== 'undefined' && evaluator.email ? decrypt(evaluator.email) : (evaluator.email || '-') %></td></tr>
          <tr><td class="text-muted">Especialidades</td><td><%= evaluator.specialties || '-' %></td></tr>
          <tr><td class="text-muted">Tipo contrato</td><td><span class="badge bg-<%= evaluator.contract_type === 'externo' ? 'info' : 'secondary' %>"><%= evaluator.contract_type || '-' %></span></td></tr>
          <tr><td class="text-muted">DJS Vigencia</td><td><%= evaluator.djs_expiry || '-' %></td></tr>
          <tr><td class="text-muted">Habilitacion CV</td><td><%= evaluator.habilitacion_cv || '-' %></td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-info-circle me-2" style="color:var(--coral)"></i> Ayuda Rapida</strong></div>
      <div class="card-body">
        <ul class="mb-0" style="font-size:0.85rem;line-height:2">
          <li>Revisa tus evaluaciones asignadas arriba</li>
          <li>Haz clic en <strong>Ver</strong> para acceder al detalle de cada evaluacion</li>
          <li>Desde el detalle puedes ver evidencias y los instrumentos aplicados</li>
          <li>Declara conflictos de interes desde <a href="/conflictos">Conflictos</a></li>
          <li>Si tu DJS esta por vencer, contacta al administrador del CEC</li>
        </ul>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>

<%- include('../partials/header', { title: 'Portal Evaluador', currentPath: '/portal' }) %>
<% const decrypt = typeof locals.decrypt === 'function' ? locals.decrypt : (v => v); %>

<% if (!evaluator) { %>
<div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Tu cuenta no esta vinculada a un evaluador. Contacta al CEC.</div>
<% } else { %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-1"><li class="breadcrumb-item"><i class="bi bi-house"></i></li><li class="breadcrumb-item active">Portal Evaluador</li></ol></nav>
    <h4 class="mb-0 fw-bold">Portal Evaluador</h4>
    <p class="text-muted mb-0">Bienvenido, <%= evaluator.name %> — gestiona tus evaluaciones, evidencias y conflictos de interes</p>
  </div>
</div>

<% alerts.forEach(a => { %>
<div class="alert alert-<%= a.type %> d-flex align-items-center"><i class="bi bi-<%= a.icon %> me-2 fs-5"></i><%= a.text %></div>
<% }) %>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-center h-100" style="border-left:4px solid var(--primary)">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:var(--primary)"><%= stats.total %></div>
        <div class="text-muted small">Total Evaluaciones</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center h-100" style="border-left:4px solid #f39c12">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:#f39c12"><%= stats.en_proceso %></div>
        <div class="text-muted small">En Proceso</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center h-100" style="border-left:4px solid #27ae60">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:#27ae60"><%= stats.completadas %></div>
        <div class="text-muted small">Completadas</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center h-100" style="border-left:4px solid #e74c3c">
      <div class="card-body py-3">
        <div class="fs-2 fw-bold" style="color:#e74c3c"><%= conflicts %></div>
        <div class="text-muted small">Conflictos</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Mis Evaluaciones</h6>
        <span class="badge bg-primary rounded-pill"><%= stats.total %></span>
      </div>
      <div class="card-body p-0">
        <% if (evaluations.length === 0) { %>
        <div class="p-4 text-center text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No tienes evaluaciones asignadas</div>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr><th>#</th><th>Candidato</th><th>Perfil</th><th>Fecha</th><th>Estado</th><th>Puntaje</th><th></th></tr></thead>
            <tbody>
            <% evaluations.forEach(e => {
              const badge = e.status === 'programada' ? 'warning' : e.status === 'en_proceso' ? 'info' : e.status === 'completada' ? 'success' : 'secondary';
              const label = e.status === 'programada' ? 'Programada' : e.status === 'en_proceso' ? 'En Proceso' : e.status === 'completada' ? 'Completada' : e.status;
            %>
            <tr>
              <td><%= e.id %></td>
              <td><%= e.candidate_name %></td>
              <td><small><%= e.profile_code || '' %></small> <%= e.profile_name || '-' %></td>
              <td><%= e.scheduled_date || '-' %></td>
              <td><span class="badge bg-<%= badge %>"><%= label %></span></td>
              <td>
                <% if (e.score_ponderado) { %>
                <span class="fw-bold" style="color: <%= e.score_ponderado >= 75 ? '#27ae60' : '#e74c3c' %>"><%= e.score_ponderado.toFixed(0) %>%</span>
                <% } else { %>-<% } %>
              </td>
              <td><a href="/portal/evaluacion/<%= e.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
            </tr>
            <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header"><h6 class="mb-0"><i class="bi bi-person-badge me-2"></i>Mi Informacion</h6></div>
      <div class="card-body">
        <div class="mb-2"><small class="text-muted d-block">Nombre</small><strong><%= evaluator.name %></strong></div>
        <div class="mb-2"><small class="text-muted d-block">RUT</small><%= decrypt(evaluator.rut) || '-' %></div>
        <div class="mb-2"><small class="text-muted d-block">Especialidades</small><%= evaluator.specialties || 'Sin definir' %></div>
        <div class="mb-2"><small class="text-muted d-block">Contrato</small><%= evaluator.contract_type || '-' %></div>
        <div class="mb-2">
          <small class="text-muted d-block">Estado DJS</small>
          <% if (evaluator.djs_expiry) {
            const days = Math.ceil((new Date(evaluator.djs_expiry) - new Date()) / 86400000);
          %>
          <span class="badge bg-<%= days > 30 ? 'success' : days > 0 ? 'warning' : 'danger' %>">
            <%= days > 0 ? 'Vigente (' + days + ' dias)' : 'VENCIDA' %>
          </span>
          <% } else { %>
          <span class="badge bg-secondary">Sin DJS</span>
          <% } %>
        </div>
        <div class="mb-2">
          <small class="text-muted d-block">Habilitacion ChileValora</small>
          <span class="badge bg-<%= evaluator.habilitacion_cv ? 'success' : 'secondary' %>">
            <%= evaluator.habilitacion_cv || 'No registrada' %>
          </span>
        </div>
        <% if (stats.tasa !== null) { %>
        <hr>
        <div class="mb-2">
          <small class="text-muted d-block">Tasa de Competencia</small>
          <div class="d-flex align-items-center gap-2">
            <div class="progress flex-grow-1" style="height:8px">
              <div class="progress-bar bg-<%= parseInt(stats.tasa) >= 70 ? 'success' : 'warning' %>" style="width:<%= stats.tasa %>%"></div>
            </div>
            <strong><%= stats.tasa %>%</strong>
          </div>
        </div>
        <% } %>
      </div>
      <div class="card-footer text-center">
        <a href="/portal/perfil" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i>Editar Perfil</a>
        <a href="/portal/portafolio" class="btn btn-sm btn-outline-secondary ms-1"><i class="bi bi-folder me-1"></i>Portafolio</a>
      </div>
    </div>

    <% if (reviews.length > 0) { %>
    <div class="card">
      <div class="card-header"><h6 class="mb-0"><i class="bi bi-star me-2"></i>Ultimas Calificaciones</h6></div>
      <div class="card-body p-0">
        <% reviews.forEach(r => { %>
        <div class="p-3 border-bottom">
          <div class="d-flex justify-content-between mb-1">
            <small class="text-muted"><%= r.period %></small>
            <small><%= r.created_at ? r.created_at.substring(0,10) : '' %></small>
          </div>
          <div class="row g-1 text-center">
            <div class="col-4"><small class="d-block text-muted">Plazos</small><strong><%= r.score_deadlines %></strong>/5</div>
            <div class="col-4"><small class="d-block text-muted">Informes</small><strong><%= r.score_report_quality %></strong>/5</div>
            <div class="col-4"><small class="d-block text-muted">Proced.</small><strong><%= r.score_procedure_compliance %></strong>/5</div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>

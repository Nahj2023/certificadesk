<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>CertificaDesk</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <div class="d-flex">
    <nav id="sidebar" class="sidebar">
      <div class="sidebar-header">
        <h5 class="mb-0">CertificaDesk</h5>
        <small class="text-muted"><%= user.org_name %></small>
      </div>
      <div class="sidebar-search px-3 py-2" style="flex-shrink:0">
        <form action="/busqueda" method="GET" autocomplete="off">
          <div class="input-group input-group-sm">
            <span class="input-group-text" style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);color:var(--sidebar-text)"><i class="bi bi-search"></i></span>
            <input type="text" name="q" class="form-control form-control-sm" placeholder="Buscar..." style="background:rgba(255,255,255,0.06);border-color:rgba(255,255,255,0.1);color:#fff" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
          </div>
        </form>
      </div>
      <ul class="nav flex-column">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
            <i class="bi bi-speedometer2"></i> Dashboard
          </a>
        </li>
        <li class="nav-section">Proc. 1 - Certificacion</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/candidatos') ? 'active' : '' %>" href="/candidatos">
            <i class="bi bi-people"></i> Candidatos
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/evaluaciones') ? 'active' : '' %>" href="/evaluaciones">
            <i class="bi bi-clipboard-check"></i> Evaluaciones
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/evidencias') ? 'active' : '' %>" href="/evidencias">
            <i class="bi bi-archive"></i> Evidencias
          </a>
        </li>
        <li class="nav-section">Proc. 2 - Auditoria</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/auditorias') ? 'active' : '' %>" href="/auditorias">
            <i class="bi bi-search"></i> Auditorias
          </a>
        </li>
        <li class="nav-section">Proc. 3 - Evaluadores</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/evaluadores') ? 'active' : '' %>" href="/evaluadores">
            <i class="bi bi-person-badge"></i> Evaluadores
          </a>
        </li>
        <li class="nav-section">Proc. 4 - Reclamos</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/reclamos') ? 'active' : '' %>" href="/reclamos">
            <i class="bi bi-chat-square-text"></i> Reclamos
          </a>
        </li>
        <li class="nav-section">Proc. 5 - Conflictos</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/conflictos') ? 'active' : '' %>" href="/conflictos">
            <i class="bi bi-exclamation-triangle"></i> Conflictos de Interes
          </a>
        </li>
        <li class="nav-section">Proc. 6 - Documentos</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/documentos') ? 'active' : '' %>" href="/documentos">
            <i class="bi bi-folder2-open"></i> Documentos
          </a>
        </li>
        <li class="nav-section">Proc. 7 - Registros</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/registros') ? 'active' : '' %>" href="/registros">
            <i class="bi bi-journal-text"></i> Control Registros
          </a>
        </li>
        <li class="nav-section">Proc. 8 - Satisfaccion</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/satisfaccion') ? 'active' : '' %>" href="/satisfaccion">
            <i class="bi bi-emoji-smile"></i> Satisfaccion
          </a>
        </li>
        <li class="nav-section">Franquicia Tributaria</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/franquicia') ? 'active' : '' %>" href="/franquicia">
            <i class="bi bi-bank"></i> Acciones EyCCL
          </a>
        </li>
        <li class="nav-section">Informes</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/reportes' ? 'active' : '' %>" href="/reportes">
            <i class="bi bi-bar-chart-line"></i> Reportes
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/reportes/chilevalora') ? 'active' : '' %>" href="/reportes/chilevalora">
            <i class="bi bi-file-earmark-bar-graph"></i> Reporte ChileValora
          </a>
        </li>
        <% if (user.role === 'admin') { %>
        <li class="nav-section">Administracion</li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/admin/usuarios') ? 'active' : '' %>" href="/admin/usuarios">
            <i class="bi bi-people-fill"></i> Usuarios
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/admin/arco' ? 'active' : '' %>" href="/admin/arco">
            <i class="bi bi-shield-check"></i> ARCO
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/admin/retencion') ? 'active' : '' %>" href="/admin/retencion">
            <i class="bi bi-database-gear"></i> Retencion
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/admin/logs' ? 'active' : '' %>" href="/admin/logs">
            <i class="bi bi-clock-history"></i> Log de acceso
          </a>
        </li>
        <% } %>
      </ul>
      <div class="sidebar-footer">
        <div class="d-flex align-items-center justify-content-between">
          <small><i class="bi bi-person-circle"></i> <%= user.display_name %> <span class="badge bg-dark" style="font-size:0.65rem"><%= user.role %></span></small>
          <a href="/logout" class="btn btn-sm btn-outline-light">Salir</a>
        </div>
      </div>
    </nav>
    <main class="main-content">
      <div class="container-fluid py-3">
        <%
          const breadcrumbMap = {
            dashboard: 'Dashboard',
            candidatos: 'Candidatos',
            evaluaciones: 'Evaluaciones',
            evaluadores: 'Evaluadores',
            auditorias: 'Auditorias',
            reclamos: 'Reclamos',
            conflictos: 'Conflictos',
            documentos: 'Documentos',
            registros: 'Registros',
            satisfaccion: 'Satisfaccion',
            franquicia: 'Franquicia',
            reportes: 'Reportes',
            evidencias: 'Evidencias',
            busqueda: 'Busqueda',
            admin: 'Administracion',
            usuarios: 'Usuarios',
            arco: 'ARCO',
            retencion: 'Retencion',
            logs: 'Log de acceso'
          };
          const pathParts = currentPath.split('/').filter(Boolean);
          const showBreadcrumb = pathParts.length > 1 || (pathParts.length === 1 && pathParts[0] !== 'dashboard');
        %>
        <% if (showBreadcrumb) { %>
        <nav aria-label="breadcrumb" class="mb-3">
          <ol class="breadcrumb mb-0" style="font-size:0.82rem">
            <li class="breadcrumb-item"><a href="/dashboard"><i class="bi bi-house-door"></i></a></li>
            <% pathParts.forEach((part, i) => {
              const isLast = i === pathParts.length - 1;
              const label = breadcrumbMap[part] || (isLast && typeof title !== 'undefined' ? title : part);
              const href = '/' + pathParts.slice(0, i + 1).join('/');
            %>
              <% if (isLast) { %>
                <li class="breadcrumb-item active" aria-current="page"><%= label %></li>
              <% } else { %>
                <li class="breadcrumb-item"><a href="<%= href %>"><%= breadcrumbMap[part] || part %></a></li>
              <% } %>
            <% }); %>
          </ol>
        </nav>
        <% } %>

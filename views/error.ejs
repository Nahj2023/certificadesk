<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CertificaDesk</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root { --coral: #E85D3A; --bg: #F3EDE4; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:var(--bg); min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .error-card { text-align:center; padding:3rem; max-width:460px; }
    .error-code { font-size:6rem; font-weight:800; color:var(--coral); line-height:1; }
    .error-title { font-size:1.5rem; font-weight:600; color:#2D3436; margin:1rem 0 0.5rem; }
    .error-msg { color:#636e72; margin-bottom:2rem; }
    .error-btn { display:inline-block; padding:0.75rem 2rem; background:var(--coral); color:#fff; text-decoration:none; border-radius:10px; font-weight:600; transition:opacity 0.2s; }
    .error-btn:hover { opacity:0.9; color:#fff; }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-code"><%= title %></div>
    <div class="error-title">Algo salio mal</div>
    <p class="error-msg"><%= message %></p>
    <a href="/dashboard" class="error-btn">Volver al dashboard</a>
  </div>
</body>
</html>
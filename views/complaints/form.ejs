<% const title = 'Nuevo Reclamo/Sugerencia' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Nuevo Registro</h4>
    <span class="text-muted" style="font-size:0.85rem">Procedimiento 4 — Reclamos, felicitaciones y sugerencias</span>
  </div>
  <a href="/reclamos" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<form method="POST" action="/reclamos">
  <div class="row g-4">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header"><i class="bi bi-chat-square-text me-2" style="color:var(--coral)"></i> Detalle del Registro</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Tipo *</label>
              <select name="type" class="form-select"><option value="reclamo">Reclamo</option><option value="felicitacion">Felicitacion</option><option value="sugerencia">Sugerencia</option></select>
            </div>
            <div class="col-md-4"><label class="form-label">Prioridad</label>
              <select name="priority" class="form-select"><option value="baja">Baja</option><option value="media" selected>Media</option><option value="alta">Alta</option></select>
            </div>
            <div class="col-md-4"><label class="form-label">Asignar a</label>
              <select name="assigned_to" class="form-select"><option value="">Sin asignar</option>
                <% staff.forEach(s => { %><option value="<%= s.id %>"><%= s.display_name %></option><% }) %>
              </select>
            </div>
            <div class="col-12"><label class="form-label">Asunto *</label><input type="text" name="subject" class="form-control" required></div>
            <div class="col-12"><label class="form-label">Descripcion</label><textarea name="description" class="form-control" rows="4"></textarea></div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-header"><i class="bi bi-person me-2" style="color:var(--coral)"></i> Remitente</div>
        <div class="card-body">
          <div class="mb-3"><label class="form-label">Nombre</label><input type="text" name="from_name" class="form-control"></div>
          <div class="mb-3"><label class="form-label">Email</label><input type="email" name="from_email" class="form-control"></div>
          <div class="mb-0"><label class="form-label">Telefono</label><input type="text" name="from_phone" class="form-control"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-4 d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Registrar</button>
    <a href="/reclamos" class="btn btn-outline-secondary">Cancelar</a>
  </div>
</form>
<%- include('../partials/footer') %>
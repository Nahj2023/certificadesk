<% const title = 'Reportes' %>
<%- include('../partials/header', { title }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-1">Reportes para ChileValora</h4>
    <span class="text-muted" style="font-size:0.85rem">Indicadores consolidados del CEC</span>
  </div>
  <a href="/reportes/chilevalora" class="btn btn-primary"><i class="bi bi-file-earmark-bar-graph"></i> Reporte Mensual</a>
</div>

<!-- KPI Summary -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card kpi-card h-100">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="kpi-gauge">
          <svg viewBox="0 0 64 64" style="width:64px;height:64px">
            <circle cx="32" cy="32" r="26" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="6"/>
            <circle cx="32" cy="32" r="26" fill="none" stroke="<%= Number(rate) >= 70 ? '#2ECC71' : Number(rate) >= 50 ? '#F39C12' : '#E74C3C' %>"
              stroke-width="6" stroke-linecap="round"
              stroke-dasharray="<%= (Number(rate) / 100 * 163.4).toFixed(1) %> 163.4"
              transform="rotate(-90 32 32)"/>
            <text x="32" y="30" text-anchor="middle" font-size="13" font-weight="800" fill="#2D3436"><%= rate %>%</text>
            <text x="32" y="40" text-anchor="middle" font-size="6" font-weight="600" fill="#636E72">TASA</text>
          </svg>
        </div>
        <div>
          <div class="kpi-label">Tasa Certificacion</div>
          <div class="kpi-detail"><%= summary.certified %> / <%= summary.candidates_total %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body py-3">
      <div class="stat-icon mx-auto green"><i class="bi bi-people"></i></div>
      <div class="fs-3 fw-bold mt-2"><%= summary.candidates_total %></div>
      <div class="stat-label">Candidatos Totales</div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body py-3">
      <div class="stat-icon mx-auto orange"><i class="bi bi-star"></i></div>
      <div class="fs-3 fw-bold mt-2"><%= summary.satisfaction_avg ? Number(summary.satisfaction_avg).toFixed(1) : '-' %><small style="font-size:0.9rem">/5</small></div>
      <div class="stat-label">Satisfaccion Prom.</div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card text-center"><div class="card-body py-3">
      <div class="stat-icon mx-auto blue"><i class="bi bi-search"></i></div>
      <div class="fs-3 fw-bold mt-2"><%= summary.audits_done %></div>
      <div class="stat-label">Auditorias</div>
    </div></div>
  </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-graph-up-arrow"></i> Tendencia de Certificaciones</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:280px">
        <canvas id="chartCertTrend"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-hexagon"></i> Satisfaccion por Dimension</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:280px">
        <canvas id="chartSatRadar"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-diagram-3"></i> Resultados por Perfil</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px">
        <canvas id="chartProfileResults"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><strong><i class="bi bi-person-badge"></i> Carga por Evaluador</strong></div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:260px">
        <canvas id="chartEvalWorkload"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- Tables -->
<div class="row g-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-award me-2" style="color:var(--coral)"></i> Resumen Certificaciones</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <tr><td class="text-muted">Certificados (Competente)</td><td class="fw-bold" style="color:var(--green)"><%= summary.certified %></td></tr>
          <tr><td class="text-muted">No Certificados</td><td class="text-danger"><%= summary.not_certified %></td></tr>
          <tr><td class="text-muted">Evaluaciones Completadas</td><td><%= summary.evaluations_done %></td></tr>
          <tr><td class="text-muted">Tasa de Certificacion</td><td class="fw-bold"><%= rate %>%</td></tr>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-shield-check me-2" style="color:var(--coral)"></i> Gestion de Calidad</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <tr><td class="text-muted">Reclamos Totales</td><td><%= summary.complaints_total %></td></tr>
          <tr><td class="text-muted">Reclamos Resueltos</td><td class="fw-bold" style="color:var(--green)"><%= summary.complaints_resolved %></td></tr>
          <tr><td class="text-muted">Tasa Resolucion</td><td><%= summary.complaints_total > 0 ? ((summary.complaints_resolved / summary.complaints_total) * 100).toFixed(0) : 0 %>%</td></tr>
          <tr><td class="text-muted">Auditorias Completadas</td><td><%= summary.audits_done %></td></tr>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
(function() {
  var coral = '#E85D3A', green = '#2ECC71', blue = '#3498DB', orange = '#F39C12',
      red = '#E74C3C', teal = '#00B894';
  Chart.defaults.font = { family: "'Inter', sans-serif", size: 11 };
  Chart.defaults.plugins.legend.labels.usePointStyle = true;
  Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(30,35,40,0.92)';
  Chart.defaults.plugins.tooltip.cornerRadius = 8;

  // 1. Certification trend
  var certData = <%- JSON.stringify(charts.certByMonth) %>;
  if (certData.length > 0) {
    var ctx1 = document.getElementById('chartCertTrend').getContext('2d');
    var gGreen = ctx1.createLinearGradient(0,0,0,260);
    gGreen.addColorStop(0, green + '44'); gGreen.addColorStop(1, green + '05');
    var gRed = ctx1.createLinearGradient(0,0,0,260);
    gRed.addColorStop(0, red + '33'); gRed.addColorStop(1, red + '05');
    new Chart(ctx1, {
      type: 'line',
      data: {
        labels: certData.map(function(d){return d.month}),
        datasets: [
          { label: 'Competentes', data: certData.map(function(d){return d.competentes}), borderColor: green, backgroundColor: gGreen, fill: true, tension: 0.4, pointRadius: 5, pointBackgroundColor: '#fff', pointBorderColor: green, pointBorderWidth: 2 },
          { label: 'No Competentes', data: certData.map(function(d){return d.no_competentes}), borderColor: red, backgroundColor: gRed, fill: true, tension: 0.4, pointRadius: 5, pointBackgroundColor: '#fff', pointBorderColor: red, pointBorderWidth: 2 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } },
        plugins: { legend: { position: 'bottom' } }
      }
    });
  } else {
    document.getElementById('chartCertTrend').parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-graph-up-arrow" style="font-size:2rem;opacity:0.3"></i><br><span style="font-size:0.85rem">Sin datos de certificaciones</span></div>';
  }

  // 2. Satisfaction radar
  var satData = <%- JSON.stringify(charts.satDims) %>;
  if (satData.total > 0) {
    new Chart(document.getElementById('chartSatRadar'), {
      type: 'radar',
      data: {
        labels: ['General', 'Evaluador', 'Proceso', 'Infraestructura', 'Comunicacion'],
        datasets: [{
          label: 'Promedio',
          data: [satData.general, satData.evaluador, satData.proceso, satData.infraestructura, satData.comunicacion],
          backgroundColor: coral + '22', borderColor: coral, borderWidth: 2,
          pointBackgroundColor: coral, pointBorderColor: '#fff', pointBorderWidth: 2, pointRadius: 5
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: { r: { beginAtZero: true, min: 0, max: 5, ticks: { stepSize: 1, font: { size: 9 }, backdropColor: 'transparent' }, grid: { color: 'rgba(0,0,0,0.06)' }, pointLabels: { font: { size: 10, weight: '600' }, color: '#636E72' }, angleLines: { color: 'rgba(0,0,0,0.06)' } } },
        plugins: { legend: { display: false } }
      }
    });
  } else {
    document.getElementById('chartSatRadar').parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-hexagon" style="font-size:2rem;opacity:0.3"></i><br><span style="font-size:0.85rem">Sin encuestas de satisfaccion</span></div>';
  }

  // 3. Results by profile
  var profData = <%- JSON.stringify(charts.byProfile) %>;
  if (profData.length > 0) {
    new Chart(document.getElementById('chartProfileResults'), {
      type: 'bar',
      data: {
        labels: profData.map(function(d){ return d.label ? (d.label.length > 20 ? d.label.substring(0,20)+'...' : d.label) : 'N/A'; }),
        datasets: [
          { label: 'Competentes', data: profData.map(function(d){return d.competentes||0}), backgroundColor: green+'CC', borderRadius: 4 },
          { label: 'No Comp.', data: profData.map(function(d){return d.no_competentes||0}), backgroundColor: red+'99', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false, indexAxis: 'y',
        scales: { x: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } }, y: { stacked: true, grid: { display: false }, ticks: { font: { size: 10 } } } },
        plugins: { legend: { position: 'bottom', labels: { font: { size: 9 } } } }
      }
    });
  } else {
    document.getElementById('chartProfileResults').parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-diagram-3" style="font-size:2rem;opacity:0.3"></i><br><span style="font-size:0.85rem">Sin datos por perfil</span></div>';
  }

  // 4. Evaluator workload
  var wlData = <%- JSON.stringify(charts.evalWorkload) %>;
  if (wlData.length > 0) {
    new Chart(document.getElementById('chartEvalWorkload'), {
      type: 'bar',
      data: {
        labels: wlData.map(function(d){ return d.name ? (d.name.length > 15 ? d.name.substring(0,15)+'...' : d.name) : 'N/A'; }),
        datasets: [{
          label: 'Evaluaciones',
          data: wlData.map(function(d){return d.evaluaciones}),
          backgroundColor: blue + 'CC',
          borderRadius: 6, barThickness: 28
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              afterLabel: function(ctx) {
                var d = wlData[ctx.dataIndex];
                return 'Tasa cert: ' + (d.tasa_cert != null ? (d.tasa_cert * 100).toFixed(0) + '%' : 'N/A');
              }
            }
          }
        }
      }
    });
  } else {
    document.getElementById('chartEvalWorkload').parentElement.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-person-badge" style="font-size:2rem;opacity:0.3"></i><br><span style="font-size:0.85rem">Sin datos de evaluadores</span></div>';
  }
})();
</script>

<%- include('../partials/footer') %>

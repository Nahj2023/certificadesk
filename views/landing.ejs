<script>
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
document.querySelectorAll('.tl-item').forEach(item => {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.2 });
  obs.observe(item);
});
</script>
<div id="lightbox">
  <button class="lb-close" id="lbClose">&times;</button>
  <button class="lb-arrow lb-prev" id="lbPrev"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg></button>
  <img id="lbImg" src="" alt="">
  <button class="lb-arrow lb-next" id="lbNext"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"/></svg></button>
</div>
<script>
(function(){
  var lb = document.getElementById('lightbox');
  var lbImg = document.getElementById('lbImg');
  var allSrcs = [];
  var curIdx = 0;
  document.querySelectorAll('.feature-visual img, .hero-track img').forEach(function(img){
    var src = img.src || img.getAttribute('src');
    if(allSrcs.indexOf(src) === -1) allSrcs.push(src);
    img.addEventListener('click', function(){
      var s = this.src;
      curIdx = allSrcs.indexOf(s);
      if(curIdx === -1){ allSrcs.push(s); curIdx = allSrcs.length - 1; }
      show(curIdx);
    });
  });
  function show(i){
    curIdx = i;
    lbImg.src = allSrcs[curIdx];
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function close(){ lb.classList.remove('active'); document.body.style.overflow = ''; }
  function nav(dir){
    curIdx += dir;
    if(curIdx < 0) curIdx = allSrcs.length - 1;
    if(curIdx >= allSrcs.length) curIdx = 0;
    lbImg.src = allSrcs[curIdx];
  }
  lb.addEventListener('click', close);
  lbImg.addEventListener('click', function(e){ e.stopPropagation(); });
  document.getElementById('lbClose').addEventListener('click', function(e){ e.stopPropagation(); close(); });
  document.getElementById('lbPrev').addEventListener('click', function(e){ e.stopPropagation(); nav(-1); });
  document.getElementById('lbNext').addEventListener('click', function(e){ e.stopPropagation(); nav(1); });
  document.addEventListener('keydown', function(e){
    if(!lb.classList.contains('active')) return;
    if(e.key==='Escape') close();
    if(e.key==='ArrowLeft') nav(-1);
    if(e.key==='ArrowRight') nav(1);
  });
})();
</script>
<script>
(function(){
  var track = document.getElementById('docsTrack');
  if(!track) return;
  var imgs = track.querySelectorAll('img');
  var dots = document.getElementById('docsDots');
  var cur = 0;
  for(var i=0;i<imgs.length;i++){
    var d = document.createElement('span');
    d.className = 'docs-dot' + (i===0?' active':'');
    d.setAttribute('data-i', i);
    d.onclick = function(){ goTo(parseInt(this.getAttribute('data-i'))); };
    dots.appendChild(d);
  }
  function goTo(n){
    cur = n;
    track.style.transform = 'translateX(-' + (cur*100) + '%)';
    dots.querySelectorAll('.docs-dot').forEach(function(d,i){ d.className = 'docs-dot' + (i===cur?' active':''); });
  }
  function move(dir){
    var next = cur + dir;
    if(next < 0) next = imgs.length - 1;
    if(next >= imgs.length) next = 0;
    goTo(next);
  }
  document.getElementById('docsPrev').addEventListener('click', function(e){ e.stopPropagation(); move(-1); });
  document.getElementById('docsNext').addEventListener('click', function(e){ e.stopPropagation(); move(1); });
  var timer = setInterval(function(){ move(1); }, 4000);
  track.parentElement.addEventListener('mouseenter', function(){ clearInterval(timer); });
  track.parentElement.addEventListener('mouseleave', function(){ timer = setInterval(function(){ move(1); }, 4000); });
})();
</script>
